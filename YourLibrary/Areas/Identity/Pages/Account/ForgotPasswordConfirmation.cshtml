@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Forgot password confirmation";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login_style.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="card shadow-sm border-0 custom-userbook-card" style="max-width: 500px; width: 100%;">

        <div class="card-header py-4 text-center login-card-header">
            <h1 class="fs-4 mb-0 fw-bold">@ViewData["Title"]</h1>
        </div>

        <div class="card-body p-5 text-center">
            <div class="text-success mb-4" style="color: #1a3a5f !important;">
                <i class="bi bi-envelope-check" style="font-size: 3.5rem;"></i>
            </div>

            <p class="fs-5 text-dark mb-4">
                Please check your email to reset your password.
            </p>

            <hr class="my-4" style="border-color: var(--accent-gold, #6fa8dc);" />

            <a href="/Identity/Account/Login" class="btn btn-login-submit px-4 py-2" style="font-size: 0.95rem !important;">
                <i class="bi bi-arrow-left me-2"></i>Back to Login
            </a>
        </div>
    </div>
</div>