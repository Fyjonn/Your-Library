@model YourLibrary.Models.UserBook

@{
    ViewData["Title"] = "Edit Book";
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_style.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5" style="max-width: 700px;">
    <div class="card shadow-sm border-0 custom-userbook-card">
        <div class="card-header d-flex justify-content-between align-items-center py-3 custom-userbook-header" style="background-color: #f8f9fa;">
            <h4 class="mb-0 text-primary"><i class="bi bi-pencil-square me-2"></i>Edit Book Settings</h4>
            <span class="badge bg-secondary fs-6">@Model.Book?.Title</span>
        </div>
        <div class="card-body p-4">

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="UserBookId" />
                <input type="hidden" asp-for="BookId" />
                <input type="hidden" asp-for="ApplicationUserId" />
                <input type="hidden" asp-for="ReviewId" />

                <div class="mb-4">
                    <label asp-for="ReadStatus" class="form-label fw-bold custom-label-muted">Reading Status</label>
                    <select asp-for="ReadStatus" class="form-select custom-input-focus">
                        <option value="Reading">Reading</option>
                        <option value="ToRead">To Read</option>
                        <option value="DNF">DNF</option>
                        <option value="Read">Read</option>
                    </select>
                    <span asp-validation-for="ReadStatus" class="text-danger fs-7"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Media" class="form-label fw-bold custom-label-muted">Media Format (e.g. Paperback, Kindle)</label>
                    <input asp-for="Media" class="form-control custom-input-focus" placeholder="e.g. Book, E-book, Audiobook" />
                    <span asp-validation-for="Media" class="text-danger fs-7"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Location" class="form-label fw-bold custom-label-muted">Shelf Location</label>
                    <input asp-for="Location" class="form-control custom-input-focus" placeholder="e.g. Bedroom shelf, Living room" />
                    <span asp-validation-for="Location" class="text-danger fs-7"></span>
                </div>

                <div class="mb-4 p-3 rounded bg-light border">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="IsOwned" name="IsOwned" value="true" @(Model.IsOwned == true ? "checked" : "") />
                        <label class="form-check-label fw-bold ms-2" for="IsOwned">I own this book</label>
                    </div>

                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="IsBorrowed" name="IsBorrowed" value="true" @(Model.IsBorrowed == true ? "checked" : "") />
                        <label class="form-check-label fw-bold ms-2" for="IsBorrowed">This book is currently borrowed</label>
                    </div>

                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="Bookmark" name="Bookmark" value="true" @(Model.Bookmark == true ? "checked" : "") />
                        <label class="form-check-label fw-bold ms-2" for="Bookmark">It has an active bookmark</label>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="form-label fw-bold custom-label-muted">Your Notes</label>
                    <textarea asp-for="Notes" class="form-control custom-input-focus" rows="3" placeholder="Add your notes or thoughts here..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger fs-7"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-4">
                    <a asp-action="Index" asp-controller="Shelf" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">
                        <i class="bi bi-check-lg me-2"></i>Save Changes
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
