@model YourLibrary.Models.UserBook
@using System.Security.Claims

@{
    ViewData["Title"] = "Edit Book";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = Model.ApplicationUserId == currentUserId;

    var isCurrentBorrower = !isOwner && Model.Borrows != null && Model.Borrows.Any(b =>
        b.ApplicationUserId == currentUserId && b.StatusBorrow == YourLibrary.Models.EnumStatusBorrow.Borrowed);

    var isPastBorrower = !isOwner && Model.Borrows != null && Model.Borrows.Any(b =>
        b.ApplicationUserId == currentUserId &&
        (b.StatusBorrow == YourLibrary.Models.EnumStatusBorrow.Returned || b.StatusBorrow == YourLibrary.Models.EnumStatusBorrow.Completed));
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_edit.css" asp-append-version="true" />
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4 mb-5 create-book-container">
    <div class="card shadow-sm border-0 custom-userbook-card">
        <div class="card-header d-flex justify-content-between align-items-center py-3 custom-userbook-header">
            <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Book Settings</h4>
            <span class="badge custom-badge-status fs-6">@Model.Book?.Title</span>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="UserBookId" />
                <input type="hidden" asp-for="BookId" />
                <input type="hidden" asp-for="ApplicationUserId" />
                <input type="hidden" asp-for="ReviewId" />

                @if (isOwner)
                {
                    <h5 class="mb-3 text-secondary border-bottom pb-2">Book Details</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Book.Title" class="form-label fw-bold custom-label-muted">Title *</label>
                            <input asp-for="Book.Title" class="form-control custom-form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Book.Author" class="form-label fw-bold custom-label-muted">Author *</label>
                            <input asp-for="Book.Author" class="form-control custom-form-control" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Book.Genre" class="form-label fw-bold custom-label-muted">Genre</label>
                            <input asp-for="Book.Genre" class="form-control custom-form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Book.AgeRating" class="form-label fw-bold custom-label-muted">Age Rating</label>
                            <input asp-for="Book.AgeRating" class="form-control custom-form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Book.Description" class="form-label fw-bold custom-label-muted">Description</label>
                        <textarea asp-for="Book.Description" class="form-control custom-form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Media" class="form-label fw-bold custom-label-muted">Media Format</label>
                        <select asp-for="Media" class="form-select custom-form-control" id="mediaSelect" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumMedia>()"></select>
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="Book.Title" />
                    <input type="hidden" asp-for="Book.Author" />
                    <input type="hidden" asp-for="Book.Genre" />
                    <input type="hidden" asp-for="Book.AgeRating" />
                    <input type="hidden" asp-for="Book.Description" />
                    <input type="hidden" asp-for="Media" id="mediaSelectHidden" value="@Model.Media" />
                }

                @if (isOwner || isCurrentBorrower)
                {
                    <div id="optionsCheckboxGroup" class="mb-3 d-none">
                        <label class="form-label fw-bold custom-label-muted mb-2">Options</label>
                        <div class="p-3 border rounded bg-white">
                            <div class="form-check mb-2" id="bookmarkWrapper">
                                <input class="form-check-input" type="checkbox" asp-for="Bookmark" id="Bookmark" />
                                <label class="form-check-label text-dark" for="Bookmark">Use Bookmark</label>
                            </div>

                            @if (isOwner)
                            {
                                <div class="form-check mb-2" id="isOwnedWrapper">
                                    <input class="form-check-input" type="checkbox" asp-for="IsOwned" id="IsOwned" />
                                    <label class="form-check-label text-dark" for="IsOwned">Is Owned</label>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (isOwner || isCurrentBorrower)
                {
                    <div class="mb-3">
                        <label asp-for="ReadStatus" class="form-label fw-bold custom-label-muted">Read Status</label>
                        <select asp-for="ReadStatus" id="readStatusSelect" class="form-select custom-form-control" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumReadStatus>()"></select>
                    </div>
                }
                else if (isPastBorrower)
                {
                    <input type="hidden" asp-for="ReadStatus" />
                }

                @if (isOwner || isCurrentBorrower)
                {
                    <div class="mb-3 d-none" id="locationGroup">
                        <label asp-for="Location" class="form-label fw-bold custom-label-muted">Storage Location</label>
                        <input asp-for="Location" class="form-control custom-form-control" id="bookLocation" />
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="Location" />
                }

                <div id="reviewRatingGroup" class="mb-3 d-none p-3 border rounded bg-light">
                    <h6 class="fw-bold mb-2 text-dark">Your Review & Rating</h6>
                    <input type="hidden" asp-for="Review.ReviewId" />

                    <div class="mb-2">
                        <label asp-for="Review.Rating" class="form-label small fw-bold">Rating</label>
                        <select asp-for="Review.Rating" id="ratingSelect" class="form-select form-select-sm custom-form-control">
                            <option value="0">Choose rating...</option>
                            @for (decimal i = 10.00m; i >= 0.00m; i -= 0.25m)
                            {
                                <option value="@i.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">@i.ToString("0.00")</option>
                            }
                        </select>
                    </div>
                    <div class="mb-0">
                        <label asp-for="Review.ReviewComment" class="form-label small fw-bold">Review Comment (Optional)</label>
                        <textarea asp-for="Review.ReviewComment" id="reviewCommentText" class="form-control custom-form-control" rows="2"></textarea>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="form-label fw-bold custom-label-muted">Your Notes & Thoughts</label>
                    <textarea asp-for="Notes" class="form-control custom-form-control" rows="4"></textarea>
                </div>

                <div class="d-flex justify-content-between align-items-center pt-3 border-top custom-form-buttons-container">
                    <a href="/Shelf/Index" class="btn btn-custom-back px-4"><i class="bi bi-arrow-left me-2"></i>Cancel</a>
                    <button type="submit" class="btn btn-custom-save px-4 shadow-sm"><i class="bi bi-check-lg me-2"></i>Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/edit.js" asp-append-version="true"></script>
}