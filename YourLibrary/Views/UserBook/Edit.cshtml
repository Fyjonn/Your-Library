@model YourLibrary.Models.UserBook

@{
    ViewData["Title"] = "Edit Book";
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_edit.css" asp-append-version="true" />
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5" style="max-width: 750px;">
    <div class="card shadow-sm border-0 custom-userbook-card">

        <div class="card-header d-flex justify-content-between align-items-center py-3 custom-userbook-header">
            <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Book Settings</h4>
            <span class="badge custom-badge-status fs-6">@Model.Book?.Title</span>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserBookId" />

                <h5 class="custom-section-title mb-3"><i class="bi bi-globe me-2"></i>General Book Information</h5>

                <div class="mb-3">
                    <label class="form-label fw-bold custom-label-muted">Book Title</label>
                    <input type="text" name="Book.Title" value="@Model.Book?.Title" class="form-control custom-form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold custom-label-muted">Author</label>
                    <input type="text" name="Book.Author" value="@Model.Book?.Author" class="form-control custom-form-control" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold custom-label-muted">Genre / Category</label>
                        <input type="text" name="Book.Genre" value="@Model.Book?.Genre" class="form-control custom-form-control" placeholder="e.g. Fantasy, Sci-Fi" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold custom-label-muted">Age Rating</label>
                        <input type="text" name="Book.AgeRating" value="@Model.Book?.AgeRating" class="form-control custom-form-control" placeholder="e.g. 16+, General" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold custom-label-muted">Book Description</label>
                    <textarea name="Book.Description" class="form-control custom-form-control" rows="3" placeholder="Brief summary of the book...">@Model.Book?.Description</textarea>
                </div>


                <h5 class="custom-section-title mb-3 pt-2 border-top"><i class="bi bi-person-gear me-2"></i>Your Personal Copy Settings</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Media" class="form-label fw-bold custom-label-muted">Media Format</label>
                        <select asp-for="Media" class="form-select custom-form-control" id="mediaFormatSelect" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumMedia>()"></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ReadStatus" class="form-label fw-bold custom-label-muted">Reading Status</label>
                        <select asp-for="ReadStatus" class="form-select custom-form-control" id="readStatusSelect" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumReadStatus>()"></select>
                    </div>
                </div>

                <div id="physicalOptionsSection">
                    <div class="row mb-3 align-items-center bg-white p-3 rounded border mx-0 custom-checkbox-box">
                        <div class="col-6 col-sm-5 border-end">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input custom-switch-input" type="checkbox" asp-for="IsOwned" id="checkboxOwned">
                                <label class="form-check-label fw-bold custom-label-muted ms-2" for="checkboxOwned">I own this book</label>
                            </div>
                        </div>
                        <div class="col-6 col-sm-7 ps-3">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input custom-switch-input" type="checkbox" asp-for="Bookmark" id="checkboxBookmark">
                                <label class="form-check-label fw-bold custom-label-muted ms-2" for="checkboxBookmark">Has a bookmark</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3" id="shelfLocationGroup">
                        <label asp-for="Location" class="form-label fw-bold custom-label-muted">Shelf Location</label>
                        <div class="input-group">
                            <span class="input-group-text custom-input-group-icon"><i class="bi bi-geo-alt-fill"></i></span>
                            <input asp-for="Location" class="form-control custom-form-control" placeholder="e.g. Living room, Top shelf" />
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="form-label fw-bold custom-label-muted">Personal Notes</label>
                    <textarea asp-for="Notes" class="form-control custom-form-control" rows="3" placeholder="Write your thoughts, memorable quotes, or private annotations here..."></textarea>
                </div>


                <div id="reviewSection" class="p-3 mb-4 rounded border custom-review-box shadow-sm" style="display:none;">
                    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-chat-left-heart-fill me-2 text-primary"></i>Your Review & Rating</h5>

                    <div class="mb-3">
                        <label class="form-label fw-bold custom-label-muted">Your Rating (Scale 1-10)</label>

                        <select id="reviewRatingSelect" name="reviewRating" class="form-select custom-form-control mb-2">
                            <option value="0">Select score...</option>
                            @for (decimal val = 1.00m; val <= 10.00m; val += 0.25m)
                            {
                                string strVal = val.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                if (Model.Review?.Rating == val)
                                {
                                    <option value="@strVal" selected>@val.ToString("0.##") / 10</option>
                                }
                                else
                                {
                                    <option value="@strVal">@val.ToString("0.##") / 10</option>
                                }
                            }
                        </select>

                        <div class="star-rating-wrapper fs-4 mb-1">
                            @for (int i = 1; i <= 10; i++)
                            {
                                <i class="bi bi-star visual-star me-1" data-value="@i"></i>
                            }
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-bold custom-label-muted">Review Comment</label>
                        <textarea name="reviewComment" class="form-control custom-form-control" rows="3" placeholder="Share your thoughts...">@Model.Review?.ReviewComment</textarea>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center pt-3 border-top custom-actions-container">
                    <a asp-action="Details" asp-route-id="@Model.UserBookId" class="btn btn-custom-back px-4">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-custom-save px-4 shadow-sm">
                        <i class="bi bi-check-lg me-2"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const mediaSelect = document.getElementById('mediaFormatSelect');
        const readStatusSelect = document.getElementById('readStatusSelect');
        const physicalOptions = document.getElementById('physicalOptionsSection');
        const reviewSection = document.getElementById('reviewSection');
        const reviewRatingInput = document.getElementById('reviewRatingInput');
        const ratingDisplayLabel = document.getElementById('ratingDisplayLabel');
        const stars = document.querySelectorAll('.star-select');

        // Logika ukrywania opcji fizycznych na podstawie Media formatu
        function toggleOptionsVisibility() {
            // Zabezpieczenie tekstowe lub numeryczne
            const selectedText = mediaSelect.options[mediaSelect.selectedIndex].text.toLowerCase();

            if (selectedText === 'ebook' || selectedText === 'audiobook') {
                physicalOptions.style.display = 'none';
                document.getElementById('checkboxOwned').checked = false;
                document.getElementById('checkboxBookmark').checked = false;
                if(document.getElementById('Location')) document.getElementById('Location').value = '';
            } else {
                physicalOptions.style.display = 'block';
            }
        }

        // 2. Logika wy£wietlania sekcji recenzji na podstawie Statusu Czytania
        function toggleReviewVisibility() {
            const statusText = readStatusSelect.options[readStatusSelect.selectedIndex].text.toLowerCase();

            // Pokazuj tylko dla "read" lub "dnf"
            if (statusText === 'read' || statusText === 'dnf') {
                reviewSection.style.display = 'block';
            } else {
                reviewSection.style.display = 'none';
                // Resetowanie warto£ci recenzji w formularzu w przypadku zmiany statusu na ToRead/Reading
                reviewRatingInput.value = '0';
                highlightStars(0);
            }
        }

        // Obs│uga systemu gwiazdek
        stars.forEach(star => {
            star.addEventListener('click', function() {
                const ratingValue = this.getAttribute('data-value');
                reviewRatingInput.value = ratingValue;
                highlightStars(ratingValue);
            });
        });

        function updateVisualStars(rating) {
            visualStars.forEach(star => {
                const starValue = parseInt(star.getAttribute('data-value'));

                // Pe│na gwiazdka
                if (rating >= starValue) {
                    star.className = 'bi bi-star-fill visual-star text-warning me-1';
                }
                // Po│¾wka lub µwiartka
                else if (rating > (starValue - 1) && rating < starValue) {
                    star.className = 'bi bi-star-half visual-star text-warning me-1';
                }
                // Pusta gwiazdka
                else {
                    star.className = 'bi bi-star visual-star text-muted me-1';
                }
            });
                }

        // Listenery zmian p¾l select
        mediaSelect.addEventListener('change', toggleOptionsVisibility);
        readStatusSelect.addEventListener('change', toggleReviewVisibility);

        // Wywo│anie przy za│adowaniu widoku w celu poprawnego ustawienia interfejsu
        document.addEventListener("DOMContentLoaded", function() {
            toggleOptionsVisibility();
            toggleReviewVisibility();

            // Inicjalizacja zaznaczonych gwiazdek na starcie pobranych z bazy
            const initialRating = parseInt(reviewRatingInput.value) || 0;
            if(initialRating > 0) {
                highlightStars(initialRating);
            }
        });
    </script>
}