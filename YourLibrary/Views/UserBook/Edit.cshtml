@model YourLibrary.Models.UserBook
@using System.Security.Claims
@using YourLibrary.Models

@{
    ViewData["Title"] = "Edit Book";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = Model.ApplicationUserId == currentUserId;

    var activeBorrow = Model.Borrows?.FirstOrDefault(b =>
        b.ApplicationUserId == currentUserId &&
        b.StatusBorrow == EnumStatusBorrow.Borrowed);

    if (activeBorrow == null)
    {
        activeBorrow = Model.Borrows?.FirstOrDefault(b =>
            b.ApplicationUserId == currentUserId &&
            (b.StatusBorrow == EnumStatusBorrow.Returned || b.StatusBorrow == EnumStatusBorrow.Completed));
    }

    var isCurrentBorrower = !isOwner && activeBorrow != null && activeBorrow.StatusBorrow == EnumStatusBorrow.Borrowed;
    var isPastBorrower = !isOwner && activeBorrow != null && (activeBorrow.StatusBorrow == EnumStatusBorrow.Returned || activeBorrow.StatusBorrow == EnumStatusBorrow.Completed);

    // kto co kiedy edytuje
    string currentLocation = isOwner ? Model.Location : activeBorrow?.BorrowerLocation;
    string currentNotes = isOwner ? Model.Notes : activeBorrow?.BorrowerNotes;
    bool currentBookmark = isOwner ? Model.Bookmark : (activeBorrow?.BorrowerBookmark ?? false);

    decimal currentRating = 0;
    string currentComment = "";

    if (isOwner)
    {
        currentRating = Model.Review?.Rating ?? 0;
        currentComment = Model.Review?.ReviewComment ?? "";
    }
    else if (activeBorrow != null)
    {
        currentRating = activeBorrow.BorrowerRating;
        currentComment = activeBorrow.BorrowerReviewComment ?? "";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_edit.css" asp-append-version="true" />
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4 mb-5 create-book-container">
    <div class="card shadow-sm border-0 custom-userbook-card">
        <div class="card-header d-flex justify-content-between align-items-center py-3 custom-userbook-header">
            <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Book Settings</h4>
            <span class="badge custom-badge-status fs-6">@Model.Book?.Title</span>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="UserBookId" />
                <input type="hidden" asp-for="BookId" />
                <input type="hidden" asp-for="ApplicationUserId" />
                <input type="hidden" asp-for="ReviewId" />

                @if (isOwner)
                {
                    <h5 class="mb-3 text-secondary border-bottom pb-2">Book Details</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Book.Title" class="form-label fw-bold custom-label-muted">Title *</label>
                            <input asp-for="Book.Title" class="form-control custom-form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Book.Author" class="form-label fw-bold custom-label-muted">Author *</label>
                            <input asp-for="Book.Author" class="form-control custom-form-control" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Book.Genre" class="form-label fw-bold custom-label-muted">Genre</label>
                            <input asp-for="Book.Genre" class="form-control custom-form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Book.AgeRating" class="form-label fw-bold custom-label-muted">Age Rating</label>
                            <input asp-for="Book.AgeRating" class="form-control custom-form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Book.Description" class="form-label fw-bold custom-label-muted">Description</label>
                        <textarea asp-for="Book.Description" class="form-control custom-form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Media" class="form-label fw-bold custom-label-muted">Media Format</label>
                        <select asp-for="Media" class="form-select custom-form-control" id="mediaSelect" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumMedia>()"></select>
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="Book.Title" />
                    <input type="hidden" asp-for="Book.Author" />
                    <input type="hidden" asp-for="Book.Genre" />
                    <input type="hidden" asp-for="Book.AgeRating" />
                    <input type="hidden" asp-for="Book.Description" />
                    <input type="hidden" asp-for="Media" id="mediaSelectHidden" value="@Model.Media" />
                }

                @if (isOwner || isCurrentBorrower)
                {
                    <div id="optionsCheckboxGroup" class="mb-3 d-none">
                        <label class="form-label fw-bold custom-label-muted mb-2">Options</label>
                        <div class="p-3 border rounded bg-white">
                            <div class="form-check mb-2" id="bookmarkWrapper">
                                <input type="checkbox" id="bookBookmark" name="Bookmark" value="true" class="form-check-input custom-form-checkbox"
                                       @(currentBookmark ? "checked=\"checked\"" : "") />
                                <label class="form-check-label text-muted" for="bookBookmark">Has Bookmark</label>
                            </div>

                            @if (isOwner)
                            {
                                <div class="form-check mb-2" id="isOwnedWrapper">
                                    <input class="form-check-input" type="checkbox" asp-for="IsOwned" id="IsOwned" />
                                    <label class="form-check-label text-dark" for="IsOwned">Is Owned</label>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (isOwner || isCurrentBorrower)
                {
                    <div class="mb-3">
                        <label asp-for="ReadStatus" class="form-label fw-bold custom-label-muted">Read Status</label>
                        <select asp-for="ReadStatus" id="readStatusSelect" class="form-select custom-form-control" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumReadStatus>()"></select>
                    </div>
                }
                else if (isPastBorrower)
                {
                    <input type="hidden" asp-for="ReadStatus" />
                }

                @if (isOwner || isCurrentBorrower)
                {
                    <div class="mb-3" id="locationGroup">
                        <label class="form-label fw-bold text-secondary">Location</label>
                        <input type="text" id="bookLocation" name="Location" class="form-control custom-form-input"
                               value="@currentLocation" placeholder="e.g., Living room shelf, Bedroom..." />
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="Location" />
                }

                <div id="reviewRatingGroup" class="mb-3 d-none p-3 border rounded bg-light">
                    <h6 class="fw-bold mb-2 text-dark">Your Review & Rating</h6>
                    <input type="hidden" asp-for="Review.ReviewId" />

                    <div class="mb-2">
                        <label asp-for="Review.Rating" class="form-label small fw-bold">Rating</label>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Rating</label>
                            <select id="ratingSelect" name="reviewRating" class="form-select custom-form-input">
                                <option value="0" selected="@(currentRating == 0 ? "selected" : null)">Choose rating...</option>
                                @for (decimal i = 1.00m; i <= 10.00m; i += 0.25m)
                                {
                                    var isSelected = Math.Abs(currentRating - i) < 0.01m;
                                    <option value="@i.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                            selected="@(isSelected ? "selected" : null)">
                                        @i.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)
                                    </option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Review Comment</label>
                        <textarea id="reviewCommentText" name="reviewComment" class="form-control custom-form-input"
                                  rows="4" placeholder="Write your thoughts about this book...">@currentComment</textarea>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Notes</label>
                    <textarea id="bookNotes" name="Notes" class="form-control custom-form-input text-start"
                              rows="3" placeholder="Add personal notes, thoughts or tags...">@currentNotes</textarea>
                </div>

                @if (isCurrentBorrower)
                {
                    <div class="border-top pt-4 mt-4">
                        <div class="d-flex justify-content-between align-items-center p-3 rounded" style="background-color: rgba(217, 83, 79, 0.05); border: 1px dashed #8b2635;">
                            <div>
                                <h6 class="mb-1 fw-bold text-danger">Return Book</h6>
                                <p class="small text-muted mb-0">Are you done reading?</p>
                                <p class="small text-muted mb-0">Give the book back to its owner.</p>
                            </div>
                            <button type="button" class="btn btn-danger btn-sm px-3" onclick="document.getElementById('returnBookForm').submit();">
                                <i class="bi bi-box-arrow-up me-1"></i>Return Book
                            </button>
                        </div>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center pt-3 border-top custom-form-buttons-container">
                    <a href="/Shelf/Index" class="btn btn-custom-back px-4"><i class="bi bi-arrow-left me-2"></i>Cancel</a>
                    <button type="submit" class="btn btn-custom-save px-4 shadow-sm"><i class="bi bi-check-lg me-2"></i>Save Changes</button>
                </div>
            </form>

            @if (isCurrentBorrower)
            {
                <form id="returnBookForm" asp-action="ReturnBorrowedBookDirectly" asp-controller="Friendship" method="post" style="display:none;">
                    <input type="hidden" name="userBookId" value="@Model.UserBookId" />
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/edit.js" asp-append-version="true"></script>
}