@model YourLibrary.Models.UserBook
@using System.Security.Claims

@{
    ViewData["Title"] = "Delete Book";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = Model.ApplicationUserId == currentUserId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_delete.css" asp-append-version="true" />
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5" style="max-width: 600px;">
    <div class="card shadow-sm border-0 custom-userbook-card border-top @(Model.IsBorrowed || !isOwner ? "border-warning" : "border-danger") border-4">
        <div class="card-body p-5 text-center">

            @if (!isOwner)
            {
                <div class="text-warning mb-3">
                    <i class="bi bi-exclamation-octagon-fill" style="font-size: 3.5rem;"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Access Denied</h3>
                <p class="text-muted mb-4">You cannot delete this book because you are not its owner. It is borrowed from a friend.</p>
            }
            else if (Model.IsBorrowed)
            {
                <div class="text-warning mb-3">
                    <i class="bi bi-lock-fill" style="font-size: 3.5rem;"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Cannot Delete Book</h3>
                <p class="text-muted mb-4">This book is borrowed by a friend. You cannot remove it from your library until they return it.</p>
            }
            else
            {
                <div class="text-danger mb-3">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size: 3.5rem;"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Remove Book?</h3>
                <p class="text-muted mb-4">Are you sure you want to completely remove this book from your application library? This action cannot be undone.</p>
            }

            <div class="p-3 rounded border bg-light text-start mb-4 mx-auto" style="max-width: 450px;">
                <div class="mb-1"><strong>Title:</strong> <span class="fs-5 text-dark fw-bold">@Model.Book?.Title</span></div>
                <div><strong>Author:</strong> <span class="text-muted">@Model.Book?.Author</span></div>
                <div class="mt-2 d-flex justify-content-between align-items-center">
                    <span class="badge bg-secondary">Shelf: @Model.ReadStatus</span>
                    @if (Model.IsBorrowed)
                    {
                        <span class="badge bg-danger"><i class="bi bi-share me-1"></i> Currently Borrowed</span>
                    }
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a asp-action="Index" asp-controller="Shelf" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left-circle me-2"></i>Back to Shelf
                </a>

                @if (isOwner && !Model.IsBorrowed)
                {
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" asp-for="UserBookId" />
                        <button type="submit" class="btn btn-danger px-4 shadow-sm">
                            <i class="bi bi-trash3-fill me-2"></i>Delete Forever
                        </button>
                    </form>
                }
            </div>

        </div>
    </div>
</div>