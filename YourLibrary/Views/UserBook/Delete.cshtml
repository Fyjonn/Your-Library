@model YourLibrary.Models.UserBook

@{
    ViewData["Title"] = "Delete Book Position";
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_delete.css" asp-append-version="true" />
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5" style="max-width: 600px;">
    <div class="card shadow-sm border-0 custom-userbook-card">
        <div class="card-header d-flex justify-content-between align-items-center py-3 bg-danger text-white">
            <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Book from Shelf</h5>
            <span class="badge bg-white text-danger fs-6">Confirmation</span>
        </div>

        <div class="card-body p-4 text-center">
            <div class="mb-4">
                <i class="bi bi-trash3 text-danger" style="font-size: 4rem;"></i>
                <h4 class="mt-2 text-dark">Are you sure?</h4>
                <p class="text-muted">You are about to permanently remove this book and all its private logs from your library shelf. This action cannot be undone.</p>
            </div>

            <div class="p-3 rounded bg-light border text-start mb-4">
                <div class="mb-2">
                    <span class="text-secondary small fw-bold uppercase">Title:</span>
                    <div class="fs-5 fw-bold text-dark">@Model.Book?.Title</div>
                </div>
                <div class="mb-2">
                    <span class="text-secondary small fw-bold">Author:</span>
                    <div class="text-dark">@Model.Book?.Author</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Location))
                {
                    <div class="mb-0">
                        <span class="text-secondary small fw-bold">Stored at:</span>
                        <div class="text-muted small">@Model.Location</div>
                    </div>
                }
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserBookId" />

                <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                    <a href="/Shelf/Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left me-2"></i>Cancel
                    </a>

                    <button type="submit" class="btn btn-danger px-4 shadow-sm">
                        <i class="bi bi-trash3-fill me-2"></i>Permanently Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>