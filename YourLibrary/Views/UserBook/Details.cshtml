@model YourLibrary.Models.UserBook
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity

@{
    ViewData["Title"] = "Details";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = Model.ApplicationUserId == currentUserId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_details.css" asp-append-version="true" />
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5" style="max-width: 700px;">
    <div class="card shadow-sm border-0 custom-userbook-card">
        <div class="card-header d-flex justify-content-between align-items-center py-3 custom-userbook-header">
            <h4 class="mb-0"><i class="bi bi-book-half me-2"></i>Info</h4>
            <span class="badge custom-badge-status fs-6">@Model.ReadStatus</span>
        </div>
        <div class="card-body p-4">

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Title:</div>
                <div class="col-sm-8 fs-5 fw-bold custom-value-title">@Model.Book?.Title</div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Author:</div>
                <div class="col-sm-8 fs-5 custom-value-dark">@Model.Book?.Author</div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Media format:</div>
                <div class="col-sm-8 custom-value-dark">@Model.Media</div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Location:</div>
                <div class="col-sm-8 custom-value-dark">
                    @(string.IsNullOrEmpty(Model.Location) ? "Not specified." : Model.Location)
                </div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-3 align-items-start align-items-sm-center">
                <div class="col-sm-4 fw-bold custom-label-muted mb-2 mb-sm-0">Ownership Status:</div>
                <div class="col-sm-8 d-flex flex-column flex-sm-row flex-wrap gap-2 w-100-mobile">
                    <div class="custom-status-tile @(Model.IsOwned ? "tile-active" : "tile-inactive") mb-1 mb-sm-0">
                        <span>@(Model.IsOwned ? "I own this book" : "I don't own this book")</span>
                    </div>

                    @if (Model.Media == YourLibrary.Models.EnumMedia.Printed)
                    {
                        <div class="custom-status-tile @(Model.Bookmark ? "tile-active" : "tile-inactive")">
                            <span>@(Model.Bookmark ? "Has a bookmark" : "No bookmark")</span>
                        </div>
                    }
                </div>
            </div>

            <div class="mb-4">
                <div class="fw-bold custom-label-muted mb-2">Your notes:</div>
                <div class="p-3 rounded custom-notes-box">
                    <span class="fst-italic">
                        @(string.IsNullOrEmpty(Model.Notes) ? "No additional notes for this book." : Model.Notes)
                    </span>
                </div>
            </div>

            @if (Model.Review != null)
            {
                <div class="mt-4 p-3 rounded custom-review-section">
                    <h5 class="fw-bold custom-label-muted mb-2">
                        <i class="bi bi-chat-left-heart-fill me-2"></i>Your Review & Thoughts
                    </h5>

                    <div class="review-stars-display mb-2 fs-5">
                        <span class="ms-2 small text-muted">(@Model.Review.Rating / 10)</span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Review.ReviewComment))
                    {
                        <p class="mb-0 italic-comment text-secondary">"@Model.Review.ReviewComment"</p>
                    }
                    else
                    {
                        <p class="mb-0 text-muted small"><em>You rated this book without leaving a written comment.</em></p>
                    }
                </div>
            }

            <div class="mt-4 text-center">
                @if (!isOwner && Model.IsOwned)
                {
                    <form asp-controller="Friendship" asp-action="RequestBorrow" method="post">
                        <input type="hidden" name="userBookId" value="@Model.UserBookId" />
                        <input type="hidden" name="friendName" value="@Model.ApplicationUser?.UserName" />
                       
                    </form>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                <a href="/Shelf/Index" class="btn btn-custom-back px-4">
                    <i class="bi bi-arrow-left me-2"></i>Back to shelf
                </a>

                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.UserBookId" class="btn btn-custom-save px-4 shadow-sm">
                        <i class="bi bi-pencil-square me-2"></i>Edit details
                    </a>

                    @if (isOwner)
                    {
                        <a asp-action="Delete" asp-route-id="@Model.UserBookId" class="btn btn-custom-delete px-4 shadow-sm">
                            <i class="bi bi-trash3-fill me-2"></i>Delete position
                        </a>
                    }
                </div>
            </div>

        </div>
    </div>
</div>