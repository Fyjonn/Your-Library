@model YourLibrary.Models.UserBook
@using System.Security.Claims

@{
    ViewData["Title"] = "Details";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = Model.ApplicationUserId == currentUserId;

    var userBorrowRecord = Model.Borrows?
        .Where(b => b.ApplicationUserId == currentUserId)
        .OrderByDescending(b => b.BorrowDate)
        .FirstOrDefault();

    var isCurrentBorrower = !isOwner && userBorrowRecord != null &&
        userBorrowRecord.StatusBorrow == YourLibrary.Models.EnumStatusBorrow.Borrowed;

    var isPastBorrower = !isOwner && userBorrowRecord != null &&
        (userBorrowRecord.StatusBorrow == YourLibrary.Models.EnumStatusBorrow.Returned ||
         userBorrowRecord.StatusBorrow == YourLibrary.Models.EnumStatusBorrow.Completed);

  
    var displayLocation = isOwner ? Model.Location : "Borrowed Item (No custom location)";
    var displayNotes = isOwner ? Model.Notes : "Notes are private to the book owner.";

    decimal displayRating = 0;
    string displayComment = "";

    if (isOwner)
    {
        if (Model.Review != null)
        {
            displayRating = Model.Review.Rating;
            displayComment = Model.Review.ReviewComment;
        }
    }
    else
    {
        if (Model.Review != null)
        {
            displayRating = Model.Review.Rating;
            displayComment = Model.Review.ReviewComment;
        }
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_details.css" asp-append-version="true" />
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5" style="max-width: 700px;">
    <div class="card shadow-sm border-0 custom-userbook-card">
        <div class="card-header d-flex justify-content-between align-items-center py-3 custom-userbook-header">
            <h4 class="mb-0"><i class="bi bi-book-half me-2"></i>Info</h4>
            <span class="badge custom-badge-status fs-6">
                @(isOwner? Model.ReadStatus.ToString() : (userBorrowRecord?.BorrowerFinalReadStatus?.ToString() ?? "Borrowing"))
            </span>
        </div>
        <div class="card-body p-4">

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Title:</div>
                <div class="col-sm-8 fs-5 fw-bold custom-value-title">@Model.Book?.Title</div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Author:</div>
                <div class="col-sm-8 fs-5 custom-value-dark">@Model.Book?.Author</div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Genre:</div>
                <div class="col-sm-8 custom-value-dark">@(string.IsNullOrEmpty(Model.Book?.Genre) ? "Not specified." : Model.Book?.Genre)</div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Description:</div>
                <div class="col-sm-8 custom-value-dark">@(string.IsNullOrEmpty(Model.Book?.Description) ? "No description available." : Model.Book?.Description)</div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Media format:</div>
                <div class="col-sm-8 custom-value-dark">@Model.Media</div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-2">
                <div class="col-sm-4 fw-bold custom-label-muted">Storage Location:</div>
                <div class="col-sm-8 custom-value-dark fw-bold text-primary">
                    @(string.IsNullOrEmpty(displayLocation) ? "Not specified." : displayLocation)
                </div>
            </div>

            <div class="row mb-3 custom-border-bottom pb-3 align-items-start align-items-sm-center">
                <div class="col-sm-4 fw-bold custom-label-muted mb-2 mb-sm-0">Ownership Status:</div>
                <div class="col-sm-8 d-flex flex-column flex-sm-row flex-wrap gap-2 w-100-mobile">
                    <div class="custom-status-tile @(isOwner && Model.IsOwned ? "tile-active" : "tile-inactive") mb-1 mb-sm-0">
                        <span>
                            @if (isOwner)
                            {
                                @(Model.IsOwned ? "I own this book" : "I don't own this book")
                            }
                            else
                            {
                                <text>You are borrowing this book (Owner: @Model.ApplicationUser?.DisplayName)</text>
                            }
                        </span>
                    </div>

                    @if (Model.Media == YourLibrary.Models.EnumMedia.Printed && isOwner)
                    {
                        <div class="custom-status-tile @(Model.Bookmark ? "tile-active" : "tile-inactive")">
                            <span>@(Model.Bookmark ? "Has a bookmark" : "No bookmark")</span>
                        </div>
                    }
                </div>
            </div>

            <div class="mb-4">
                <div class="fw-bold custom-label-muted mb-2">Personal Notes:</div>
                <div class="p-3 rounded custom-notes-box bg-white">
                    <span class="fst-italic text-dark">
                        @(string.IsNullOrEmpty(displayNotes) ? "No additional notes for this book." : displayNotes)
                    </span>
                </div>
            </div>

            @if (displayRating > 0)
            {
                <div class="mt-4 p-3 rounded custom-review-section">
                    <h5 class="fw-bold custom-label-muted mb-2">
                        <i class="bi bi-chat-left-heart-fill me-2"></i>Book Rating & Review
                    </h5>

                    <div class="review-stars-display mb-2 fs-5">
                        <span class="fw-bold text-warning"><i class="bi bi-star-fill me-1"></i>@displayRating.ToString("0.00")</span>
                        <span class="ms-1 small text-muted">/ 10</span>
                    </div>

                    @if (!string.IsNullOrEmpty(displayComment))
                    {
                        <p class="mb-0 italic-comment text-secondary">"@displayComment"</p>
                    }
                    else
                    {
                        <p class="mb-0 text-muted small">
                            <em><i class="bi bi-info-circle me-1"></i>A numeric rating was submitted without an accompanying text comment.</em>
                        </p>
                    }
                </div>
            }
            else
            {
                <div class="mt-4 p-2 rounded bg-light text-muted small text-center">
                    <em><i class="bi bi-star me-1"></i>No active rating or review comment has been published yet.</em>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-4">
                <a href="/Shelf/Index" class="btn btn-custom-back px-4">
                    <i class="bi bi-arrow-left me-2"></i>Back to shelf
                </a>

                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.UserBookId" class="btn btn-custom-save px-4 shadow-sm">
                        <i class="bi bi-pencil-square me-2"></i>Edit details
                    </a>

                    @if (isOwner)
                    {
                        <a asp-action="Delete" asp-route-id="@Model.UserBookId" class="btn btn-custom-delete px-4 shadow-sm">
                            <i class="bi bi-trash3-fill me-2"></i>Delete position
                        </a>
                    }
                </div>
            </div>

        </div>
    </div>
</div>