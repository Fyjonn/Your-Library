@model YourLibrary.Models.UserBook

@{
    ViewData["Title"] = "Details";
}

<div class="container mt-4" style="max-width: 700px;">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Information about the book</h4>
            <span class="badge bg-light text-primary fs-6">@Model.ReadStatus</span>
        </div>
        <div class="card-body p-4">

            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted">Title:</div>
                <div class="col-sm-8 fs-5 fw-bold text-dark">@Model.Book?.Title</div>
            </div>

            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted">Author:</div>
                <div class="col-sm-8 fs-5 text-secondary">@Model.Book?.Author</div>
            </div>

            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted"> Media format:</div>
                <div class="col-sm-8">@Model.Media</div>
            </div>

            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted">Location:</div>
                <div class="col-sm-8">
                    @(string.IsNullOrEmpty(Model.Location) ? "Not specified." : Model.Location)</div>
            </div>

            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted">Ownership Status:</div>
                <div class="col-sm-8">
                    <span class="badge @(Model.IsOwned ? "bg-success" : "bg-secondary") me-1">
                        @(Model.IsOwned ? "I own this book." : "I don't own this book.")
                    </span>
                    <span class="badge @(Model.IsBorrowed ? "bg-warning text-dark" : "bg-secondary") me-1">
                        @(Model.IsBorrowed ? "Borrowed." : "Not borrowed.")
                    </span>
                    <span class="badge @(Model.Bookmark ? "bg-info text-dark" : "bg-secondary")">
                        @(Model.Bookmark ? "It has a bookmark." : "No bookmark.")
                    </span>
                </div>
            </div>

            <div class="mb-4">
                <div class="fw-bold text-muted mb-1">Twoje notatki:</div>
                <div class="p-3 bg-light rounded border-start border-primary border-3">
                    <span class="fst-italic text-dark">
                        @(string.IsNullOrEmpty(Model.Notes) ? "No additional notes for this book." : Model.Notes)
                    </span>
                </div>
            </div>

            <div class="d-flex justify-content-between pt-2">
                <a href="/Shelf" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Back to shelf
                </a>
            </div>

        </div>
    </div>
</div>