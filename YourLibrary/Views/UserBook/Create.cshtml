@model YourLibrary.Models.UserBook

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">➕ Dodaj książkę do swojej półki</h4>
        </div>
        <div class="card-body">

            <div class="mb-4 p-3 bg-light border rounded">
                <label class="form-label fw-bold text-primary">🔍 Znajdź książkę automatycznie w Google</label>
                <div class="input-group">
                    <input type="text" id="apiSearchQuery" class="form-control" placeholder="Search by title or author" />
                    <button class="btn btn-primary" type="button" id="btnSearchApi">Search</button>
                </div>
                <div id="apiResults" class="list-group mt-2 shadow-sm d-none"></div>
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <h5 class="text-secondary border-bottom pb-2">Your book</h5>
                <div class="mb-3">
                    <label asp-for="Book.Title" class="form-label">Title</label>
                    <input asp-for="Book.Title" id="bookTitle" class="form-control" required readonly />
                </div>
                <div class="mb-3">
                    <label asp-for="Book.Author" class="form-label">Author</label>
                    <input asp-for="Book.Author" id="bookAuthor" class="form-control" required readonly />
                </div>

                <h5 class="text-secondary border-bottom pb-2 mt-4">My shelf</h5>
                <div class="mb-3">
                    <label asp-for="Media" class="form-label">Media format</label>
                    <select asp-for="Media" class="form-select" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumMedia>()">
                        <option value="">-- Select format --</option>
                    </select>
                    <span asp-validation-for="Media" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ReadStatus" class="form-label">Read status</label>
                    <select asp-for="ReadStatus" class="form-select" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumReadStatus>()">
                        <option value="">-- Select status --</option>
                    </select>
                    <span asp-validation-for="ReadStatus" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="Bookmark">
                        <label class="form-check-label" asp-for="Bookmark">Do you have a bookmark in your book?</label>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="IsOwned">
                        <label class="form-check-label" asp-for="IsOwned">Do u own this book?</label>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="IsBorrowed">
                        <label class="form-check-label" asp-for="IsBorrowed">Is this book borrowed?</label>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="form-label">Where do you keep your book?</label>
                    <input asp-for="Location" class="form-control" placeholder="eg. Bedroom, desk..." />
                </div>
                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">Your notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="ViewAll" class="btn btn-outline-secondary">Anuluj</a>
                    <button type="submit" class="btn btn-success px-4">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('btnSearchApi').addEventListener('click', function () {
            const query = document.getElementById('apiSearchQuery').value;
            const resultsDiv = document.getElementById('apiResults');

            if (!query) return;

            resultsDiv.innerHTML = '<div class="list-group-item text-muted">Szukanie w Google Books...</div>';
            resultsDiv.classList.remove('d-none');

            fetch(`/api/books/search?query=${encodeURIComponent(query)}`)
                .then(response => response.json())
                .then(data => {
                    resultsDiv.innerHTML = '';

                    if (!data.items || data.items.length === 0) {
                        resultsDiv.innerHTML = '<div class="list-group-item text-danger">Nie znaleziono żadnej książki.</div>';
                        return;
                    }

                    data.items.forEach(item => {
                        const title = item.volumeInfo.title || "Brak tytułu";
                        const authors = item.volumeInfo.authors ? item.volumeInfo.authors.join(', ') : "Nieznany autor";

                        const button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'list-group-item list-group-item-action text-start';
                        button.innerHTML = `<strong>${title}</strong> <br><small class="text-muted">${authors}</small>`;

                        button.addEventListener('click', function () {
                            document.getElementById('bookTitle').value = title;
                            document.getElementById('bookAuthor').value = authors;

                            resultsDiv.classList.add('d-none');
                            resultsDiv.innerHTML = '';
                        });

                        resultsDiv.appendChild(button);
                    });
                })
                .catch(error => {
                    resultsDiv.innerHTML = '<div class="list-group-item text-danger">Błąd podczas pobierania danych.</div>';
                    console.error(error);
                });
        });
    </script>
}
