@model YourLibrary.Models.UserBook

@{
    ViewData["Title"] = "Add Book to Shelf";
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_create.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4 mb-5 create-book-container">
    <div class="row g-4">

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 custom-userbook-card">
                <div class="card-header py-3 custom-userbook-header">
                    <h4 class="mb-0"><i class="bi bi-bookmark-plus me-2"></i>Add book to your shelf</h4>
                </div>
                <div class="card-body p-4">

                    <div class="mb-4 p-3 rounded border custom-search-box" id="apiSearchSection">
                        <label class="form-label fw-bold custom-label-muted"><i class="bi bi-search me-1"></i> Search book</label>
                        <div class="input-group">
                            <input type="text" id="apiSearchQuery" class="form-control custom-form-control border-end-0" placeholder="Search by title or author..." />
                            <button class="btn btn-custom-save px-4" type="button" id="btnSearchApi">Search</button>
                        </div>
                        <div id="apiResults" class="list-group mt-2 shadow d-none" style="max-height: 250px; overflow-y: auto; position: absolute; z-index: 1000; width: calc(100% - 48px);"></div>
                    </div>

                    <div class="form-check form-switch mb-4 p-3 rounded border bg-white custom-checkbox-group">
                        <input class="form-check-input ms-0 me-2" type="checkbox" id="switchManualMode" name="isManualMode" value="true">
                        <label class="form-check-label fw-bold custom-label-muted" for="switchManualMode">
                            <i class="bi bi-pencil-square me-1"></i> Add book manually
                        </label>
                    </div>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="custom-label-muted border-bottom pb-2 mb-3"><i class="bi bi-book me-2"></i>Your book</h5>

                        <div class="text-center mb-4 d-none" id="coverPreviewContainer">
                            <img id="bookCoverPreview" src="" alt="Book Cover Preview" class="img-thumbnail shadow-sm rounded" style="max-height: 180px; border: 2px solid var(--accent-gold);" />
                            <input type="hidden" asp-for="Book.ImageURL" id="bookImageUrl" />
                        </div>

                        @* <div class="form-group mb-3 d-none" id="manualCoverGroup"> *@
                        @*     <label class="form-label custom-label-muted"><i class="bi bi-image me-1"></i> Upload book cover image</label> *@
                        @*     <input type="file" name="coverFile" id="manualCoverFile" class="form-control custom-form-control" accept="image/*" /> *@
                        @* </div> *@
                        <div class="form-group mb-3 d-none" id="manualCoverGroup">
                            <label class="form-label custom-label-muted">
                                <i class="bi bi-image me-1"></i>
                                Upload book cover image
                            </label>

                            <input type="file"
                                   name="coverFile"
                                   id="manualCoverFile"
                                   accept="image/*"
                                   style="display:none;" />

                            <div>
                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        onclick="document.getElementById('manualCoverFile').click()">
                                    Choose file
                                </button>

                                <span id="selectedFileName" class="ms-2">
                                    No file chosen
                                </span>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Book.Title" class="form-label custom-label-muted">Title</label>
                            <input asp-for="Book.Title" id="bookTitle" class="form-control custom-form-control" required readonly />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Book.Author" class="form-label custom-label-muted">Author</label>
                            <input asp-for="Book.Author" id="bookAuthor" class="form-control custom-form-control" required readonly />
                        </div>
                        <div class="form-group mb-3">
                            <label class="control-label custom-label-muted">Genre</label>
                            <input asp-for="Book.Genre" id="bookGenre" class="form-control custom-form-control" readonly />
                            <span asp-validation-for="Book.Genre" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label class="control-label custom-label-muted">Age Rating</label>
                            <input asp-for="Book.AgeRating" id="bookAgeRating" class="form-control custom-form-control" readonly />
                            <span asp-validation-for="Book.AgeRating" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label class="control-label custom-label-muted">Description</label>
                            <textarea asp-for="Book.Description" id="bookDescription" class="form-control custom-form-control" rows="4" readonly></textarea>
                            <span asp-validation-for="Book.Description" class="text-danger"></span>
                        </div>

                        <h5 class="custom-label-muted border-bottom pb-2 mt-4 mb-3"><i class="bi bi-layers me-2"></i>My shelf</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Media" class="form-label custom-label-muted">Media format</label>
                                <select asp-for="Media" id="mediaSelect" class="form-select custom-form-control" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumMedia>()">
                                    <option value="">-- Select format --</option>
                                </select>
                                <span asp-validation-for="Media" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ReadStatus" class="form-label custom-label-muted">Read status</label>
                                <select asp-for="ReadStatus" id="readStatusSelect" class="form-select custom-form-control" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumReadStatus>()">
                                    <option value="">-- Select status --</option>
                                </select>
                                <span asp-validation-for="ReadStatus" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-3 p-3 rounded custom-checkbox-group d-none" id="optionsCheckboxGroup">
                            <label class="form-label d-block custom-label-muted mb-2"><i class="bi bi-sliders me-1"></i> Options</label>

                            <div class="form-check mb-2" id="bookmarkWrapper">
                                <input class="form-check-input" type="checkbox" id="Bookmark" name="Bookmark" value="true" @(Model?.Bookmark == true ? "checked" : "")>
                                <label class="form-check-label custom-value-dark" for="Bookmark">Do you have a bookmark in your book?</label>
                            </div>

                            <div class="form-check mb-2" id="ownedWrapper">
                                <input class="form-check-input" type="checkbox" id="IsOwned" name="IsOwned" value="true" @(Model?.IsOwned == true ? "checked" : "")>
                                <label class="form-check-label custom-value-dark" for="IsOwned">Do you own this book?</label>
                            </div>

                        </div>
                        <div class="mb-3 d-none" id="locationGroup">
                            <label asp-for="Location" class="form-label custom-label-muted">Where do you keep your book?</label>
                            <input asp-for="Location" id="bookLocation" class="form-control custom-form-control" placeholder="e.g. Bedroom, desk, main shelf..." />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label custom-label-muted">Your notes</label>
                            <textarea asp-for="Notes" class="form-control custom-form-control" rows="3" placeholder="Add your personal thoughts..."></textarea>
                        </div>
                        <div class="mb-4 d-none" id="reviewInputGroup">
                            <h5 class="custom-label-muted border-bottom pb-2 mt-4 mb-3">
                                <i class="bi bi-chat-left-heart me-2"></i>Add your review
                            </h5>

                            <div id="reviewBlockedAlert" class="alert alert-warning d-none" style="border: 1px solid var(--accent-gold); background-color: var(--card-bg); color: var(--text-dark);">
                                <i class="bi bi-exclamation-triangle-fill me-2" style="color: var(--retro-burgund);"></i>
                                Please find/add a book first and ensure title and author are filled to write a review!
                            </div>

                            <div id="reviewFieldsContainer">
                                <div class="mb-3 row align-items-center">
                                    <div class="col-md-5">
                                        <label class="form-label custom-label-muted">Your Rating (1-10)</label>
                                        <select id="reviewRatingSelect" name="reviewRating" class="form-select custom-form-control">
                                            <option value="0">-- Choose rating --</option>
                                            @for (decimal i = 10.00m; i >= 1.00m; i -= 0.25m)
                                            {
                                                <option value="@i.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">@i.ToString("F2")</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-7 pt-4">
                                        <div class="star-rating-wrapper fs-4" id="visualStarsDisplay">
                                            @for (int s = 1; s <= 10; s++)
                                            {
                                                <i class="bi bi-star visual-star" data-value="@s"></i>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group mb-3">
                                    <label class="form-label custom-label-muted">Review Comment</label>
                                    <textarea name="reviewComment" id="reviewCommentInput" class="form-control custom-form-control" rows="3" placeholder="Write your thoughts about this book..."></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between pt-2">
                            <a asp-controller="Shelf" asp-action="Index" class="btn btn-custom-back px-4">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-custom-save px-4">
                                <i class="bi bi-check-lg me-2"></i>Save book
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 reviews-sidebar-card">
                <div class="card-header py-3 custom-userbook-header">
                    <h4 class="mb-0"><i class="bi bi-chat-heart me-2"></i>Community Reviews</h4>
                </div>
                <div class="card-body p-4">
                    <div id="reviewsPlaceholder" class="text-center py-5 text-muted">
                        <i class="bi bi-book-half d-block display-4 mb-3 text-secondary"></i>
                        <p id="placeholderText">Select or add a book to load user reviews and thoughts.</p>
                    </div>
                    <div id="reviewsContainer" class="d-none">
                        <div id="reviewsList"></div>
                        <div class="text-center mt-3">
                            <span id="btnToggleReviews" class="btn-toggle-reviews d-none">Show all reviews</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/create.js" asp-append-version="true"></script>

    <script>
        const coverInput = document.getElementById("manualCoverFile");
        const fileNameLabel = document.getElementById("selectedFileName");

        if (coverInput) {
            coverInput.addEventListener("change", function () {

                if (this.files.length > 0) {
                    fileNameLabel.textContent = this.files[0].name;
                }
                else {
                    fileNameLabel.textContent = "No file chosen";
                }
            });
        }
    </script>
}