@model YourLibrary.Models.UserBook

@{
    ViewData["Title"] = "Add Book to Shelf";
}

@section Styles {
    <link rel="stylesheet" href="~/css/userbook_style.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4 mb-5" style="max-width: 650px;">
    <div class="card shadow-sm border-0 custom-userbook-card">

        <!-- Nagłówek -->
        <div class="card-header py-3 custom-userbook-header">
            <h4 class="mb-0"><i class="bi bi-bookmark-plus me-2"></i>Add book to your shelf</h4>
        </div>

        <div class="card-body p-4">

            <!-- Sekcja Wyszukiwarki Google Books dopasowana do stylu retro -->
            <div class="mb-4 p-3 rounded border">
                <label class="form-label fw-bold custom-label-muted"><i class="bi bi-search me-1"></i> Find your book via Google</label>
                <div class="input-group custom-search-group">
                    <input type="text" id="apiSearchQuery" class="form-control custom-form-control border-end-0" placeholder="Search by title or author..." />
                    <button class="btn btn-custom-save px-4" type="button" id="btnSearchApi">Search</button>
                </div>
                <!-- Dropdown wyników wyszukiwania w kolorach kremowo-zielonych -->
                <div id="apiResults" class="list-group mt-2 shadow custom-dropdown-menu d-none" style="max-height: 250px; overflow-y: auto; position: absolute; z-index: 1000; width: calc(100% - 48px);"></div>
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Dane książki (uzupełniane automatycznie przez API) -->
                <h5 class="custom-label-muted border-bottom pb-2 mb-3"><i class="bi bi-book me-2"></i>Your book</h5>
                <div class="mb-3">
                <div class="text-center mb-4 d-none" id="coverPreviewContainer">
                    <img id="bookCoverPreview" src="" alt="Book Cover Preview" class="img-thumbnail shadow-sm rounded" style="max-height: 180px; border: 2px solid var(--accent-gold);" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Book.Title" class="form-label custom-label-muted">Title</label>
                    <input asp-for="Book.Title" id="bookTitle" class="form-control custom-form-control" style="opacity: 0.85;" required readonly />
                </div>
                <div class="mb-3">
                    <label asp-for="Book.Author" class="form-label custom-label-muted">Author</label>
                    <input asp-for="Book.Author" id="bookAuthor" class="form-control custom-form-control" style="opacity: 0.85;" required readonly />
                </div>

                <div class="form-group mb-3">
                    <label class="control-label custom-label-muted">Genre</label>
                    <input asp-for="Book.Genre" id="bookGenre" class="form-control custom-input-dark" />
                    <span asp-validation-for="Book.Genre" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label custom-label-muted">Age Rating</label>
                    <input asp-for="Book.AgeRating" id="bookAgeRating" class="form-control custom-input-dark" />
                    <span asp-validation-for="Book.AgeRating" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label custom-label-muted">Description</label>
                    <textarea asp-for="Book.Description" id="bookDescription" class="form-control custom-input-dark" rows="4"></textarea>
                    <span asp-validation-for="Book.Description" class="text-danger"></span>
                </div>

                <!-- Parametry półki użytkownika -->
                <h5 class="custom-label-muted border-bottom pb-2 mt-4 mb-3"><i class="bi bi-layers me-2"></i>My shelf</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Media" class="form-label custom-label-muted">Media format</label>
                        <select asp-for="Media" id="mediaSelect" class="form-select custom-form-control" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumMedia>()">
                            <option value="">-- Select format --</option>
                        </select>
                        <span asp-validation-for="Media" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ReadStatus" class="form-label custom-label-muted">Read status</label>
                        <select asp-for="ReadStatus" class="form-select custom-form-control" asp-items="Html.GetEnumSelectList<YourLibrary.Models.EnumReadStatus>()">
                            <option value="">-- Select status --</option>
                        </select>
                        <span asp-validation-for="ReadStatus" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Statusy (Checkboxy retro w ujednoliconym panelu) -->
                <div class="mb-3 p-3 rounded custom-checkbox-group d-none" id="optionsCheckboxGroup" >
                    <label class="form-label d-block custom-label-muted mb-2"><i class="bi bi-sliders me-1"></i> Options</label>

                    <div class="form-check custom-checkbox mb-2">
                        <input class="form-check-input" type="checkbox" id="Bookmark" name="Bookmark" value="true" @(Model?.Bookmark == true ? "checked" : "")>
                        <label class="form-check-label custom-value-dark" for="Bookmark">Do you have a bookmark in your book?</label>
                    </div>

                    <div class="form-check custom-checkbox mb-2">
                        <input class="form-check-input" type="checkbox" id="IsOwned" name="IsOwned" value="true" @(Model?.IsOwned == true ? "checked" : "")>
                        <label class="form-check-label custom-value-dark" for="IsOwned">Do you own this book?</label>
                    </div>

                    <div class="form-check custom-checkbox">
                        <input class="form-check-input" type="checkbox" id="IsBorrowed" name="IsBorrowed" value="true" @(Model?.IsBorrowed == true ? "checked" : "")>
                        <label class="form-check-label custom-value-dark" for="IsBorrowed">Is this book borrowed?</label>
                    </div>
                </div>

                <!-- Miejsce przechowywania i notatki -->
                <div class="mb-3 d-none" id="locationGroup">
                    <label asp-for="Location" class="form-label custom-label-muted">Where do you keep your book?</label>
                    <input asp-for="Location" id="bookLocation" class="form-control custom-form-control" placeholder="e.g. Bedroom, desk, main shelf..." />
                </div>
                <div class="mb-4">
                    <label asp-for="Notes" class="form-label custom-label-muted">Your notes</label>
                    <textarea asp-for="Notes" class="form-control custom-form-control" rows="3" placeholder="Add your personal thoughts..."></textarea>
                </div>

                <!-- Przyciski akcji -->
                <div class="d-flex justify-content-between pt-2">
                    <a asp-controller="Shelf" asp-action="Index" class="btn btn-custom-back px-4">
                        <i class="bi bi-arrow-left me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-custom-save px-4">
                        <i class="bi bi-check-lg me-2"></i>Save changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let debounceTimer;

        document.getElementById('apiSearchQuery').addEventListener('input', function () {
            const originalQuery = this.value.trim();
            const resultsDiv = document.getElementById('apiResults');

            if (!originalQuery) {
                resultsDiv.innerHTML = '';
                resultsDiv.classList.add('d-none');
                return;
            }

            clearTimeout(debounceTimer);

            debounceTimer = setTimeout(() => {
                resultsDiv.innerHTML = '<div class="list-group-item text-muted bg-transparent border-0 italic-loading">🔍 Searching in Google Books...</div>';
                resultsDiv.classList.remove('d-none');

                fetch(`/api/books/search?query=${encodeURIComponent(originalQuery)}`)
                    .then(response => response.json())
                    .then(data => {
                        resultsDiv.innerHTML = '';

                        if (!data.items || data.items.length === 0) {
                            resultsDiv.innerHTML = '<div class="list-group-item text-danger bg-transparent border-0">No book found.</div>';
                            return;
                        }

                        data.items.forEach(item => {
                            const title = item.volumeInfo.title || "No title";
                            const authors = item.volumeInfo.authors ? item.volumeInfo.authors.join(', ') : "Unknown author";
                            const description = item.volumeInfo.description || "";
                            const genre = item.volumeInfo.categories ? item.volumeInfo.categories.join(', ') : "";
                            const ageRating = item.volumeInfo.maturityRating === "MATURE" ? "18+" : "General";

                            const imageUrl = item.volumeInfo.imageLinks ? item.volumeInfo.imageLinks.thumbnail : "https://via.placeholder.com/40x60?text=No+Cover";

                            const button = document.createElement('button');
                            button.type = 'button';
                            button.className = 'list-group-item list-group-item-action text-start api-result-item d-flex align-items-center gap-3 py-2';

                            button.innerHTML = `
                                <img src="${imageUrl}" alt="cover" class="rounded shadow-sm" style="width: 40px; height: 60px; object-fit: cover; flex-shrink: 0;" />
                                <div class="flex-grow-1">
                                    <strong class="d-block text-dark">${title}</strong>
                                    <small class="text-muted-custom">${authors}</small>
                                </div>
                            `;

                            button.addEventListener('click', function () {
                                document.getElementById('bookTitle').value = title;
                                document.getElementById('bookAuthor').value = authors;
                                if(document.getElementById('bookDescription')) document.getElementById('bookDescription').value = description;
                                if(document.getElementById('bookGenre')) document.getElementById('bookGenre').value = genre;
                                if(document.getElementById('bookAgeRating')) document.getElementById('bookAgeRating').value = ageRating;
                                if(document.getElementById('bookImageUrl')) document.getElementById('bookImageUrl').value = imageUrl;

                                const previewImg = document.getElementById('bookCoverPreview');
                                const previewContainer = document.getElementById('coverPreviewContainer');
                                if (previewImg && previewContainer) {
                                    previewImg.src = imageUrl;
                                    previewContainer.classList.remove('d-none');
                                }

                                resultsDiv.classList.add('d-none');
                                resultsDiv.innerHTML = '';
                                document.getElementById('apiSearchQuery').value = '';
                            });

                            resultsDiv.appendChild(button);
                        });
                    })
                    .catch(error => {
                        resultsDiv.innerHTML = '<div class="list-group-item text-danger bg-transparent border-0">Error while downloading data.</div>';
                        console.error(error);
                    });
            }, 400);
        });

        document.addEventListener('click', function (e) {
            const resultsDiv = document.getElementById('apiResults');
            if (e.target.id !== 'apiSearchQuery') {
                resultsDiv.classList.add('d-none');
            }
        });
        const mediaSelect = document.getElementById('mediaSelect');
        const optionsGroup = document.getElementById('optionsCheckboxGroup');
        const locationGroup = document.getElementById('locationGroup');

        function toggleOptionsVisibility() {
            const selectedText = mediaSelect.options[mediaSelect.selectedIndex].text.toLowerCase();


            if (selectedText.includes('print')) {
                optionsGroup.classList.remove('d-none');
                locationGroup.classList.remove('d-none');
            } else {
                optionsGroup.classList.add('d-none');
                locationGroup.classList.add('d-none');

                document.getElementById('Bookmark').checked = false;
                document.getElementById('IsOwned').checked = false;
                document.getElementById('IsBorrowed').checked = false;

                const locationInput = document.getElementById('bookLocation');
                if (locationInput) {
                    locationInput.value = ''; // Czyszczenie wpisanej lokalizacji
                }
            }
        }

        mediaSelect.addEventListener('change', toggleOptionsVisibility);

        if (mediaSelect.value) {
            toggleOptionsVisibility();
        }
    </script>
}

