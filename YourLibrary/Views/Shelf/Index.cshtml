@model IEnumerable<YourLibrary.Models.UserBook>
@using System.Security.Claims
@using YourLibrary.Models
@{
    ViewData["Title"] = "My Shelf";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

@section Styles {
    <link rel="stylesheet" href="~/css/shelf_style.css" asp-append-version="true" />
    <style>
        .history-returned-row {
            background-color: #f0f4f8 !important;
            color: #6c757d !important;
            opacity: 0.75;
        }

            .history-returned-row .custom-book-title-cell,
            .history-returned-row .custom-author-text {
                color: #6c757d !important;
            }
    </style>
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4 pb-5 position-relative library-shelf-container">

    <div class="text-center mb-4">
        <h1 id="current-shelf-title" class="display-5 fw-bold custom-shelf-title">Reading</h1>
    </div>

    <div class="d-flex justify-content-center mb-4">
        <div class="dropdown shadow-sm">
            <button class="btn btn-custom-dropdown btn-lg dropdown-toggle px-4" type="button" id="shelfDropdownMenu" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-filter-left me-2"></i>Select shelf
            </button>
            <ul class="dropdown-menu dropdown-menu-end text-center shadow custom-dropdown-menu" aria-labelledby="shelfDropdownMenu">
                <li><button class="dropdown-item active" type="button" data-shelf-target="#reading"><i class="bi bi-book-half me-2"></i>Reading</button></li>
                <li><button class="dropdown-item" type="button" data-shelf-target="#toread"><i class="bi bi-bookmark-plus me-2"></i>To Read</button></li>
                <li><button class="dropdown-item" type="button" data-shelf-target="#dnf"><i class="bi bi-x-circle me-2"></i>DNF</button></li>
                <li><button class="dropdown-item" type="button" data-shelf-target="#read"><i class="bi bi-check2-circle me-2"></i>Read</button></li>
            </ul>
        </div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="input-group shadow-sm mb-2 custom-search-group">
                <span class="input-group-text border-end-0 text-muted custom-search-icon">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" id="shelfSearchInput" class="form-control border-start-0 ps-1 custom-search-input" placeholder="Search books on this shelf..." />
            </div>
            <div class="d-flex justify-content-center gap-3 fs-7 custom-radio-group">
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="searchType" id="searchByTitle" value="title" checked>
                    <label class="form-check-label" for="searchByTitle">Title</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="searchType" id="searchByAuthor" value="author">
                    <label class="form-check-label" for="searchByAuthor">Author</label>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-content" id="shelfTabsContent">
        @{
            // PANCERNE GLOBALNE GRUPOWANIE: Spaja powtarzające się BookId w jeden logiczny rekord na tym widoku
            var uniqueUserBooks = Model
                .GroupBy(b => b.BookId)
                .Select(g =>
                {
                    // 1. Szukamy rekordu, który ma AKTUALNE aktywne wypożyczenie (zielona książka)
                    var activeBorrowRow = g.FirstOrDefault(b => b.ApplicationUserId != currentUserId &&
                                                               b.Borrows?.Any(br => br.ApplicationUserId == currentUserId && br.StatusBorrow == EnumStatusBorrow.Borrowed) == true);

                    if (activeBorrowRow != null) return activeBorrowRow;

                    // 2. Szukamy rekordu, który oczekuje na potwierdzenie zwrotu (ma pierwszeństwo przed zakończonymi duchami)
                    var returnedBorrowRow = g.FirstOrDefault(b => b.ApplicationUserId != currentUserId &&
                                                                b.Borrows?.Any(br => br.ApplicationUserId == currentUserId && br.StatusBorrow == EnumStatusBorrow.Returned) == true);

                    if (returnedBorrowRow != null) return returnedBorrowRow;

                    // 3. Sprawdzamy, czy ta książka ma NOWE aktywne wypożyczenie na innej półce.
                    // Jeśli tak, nie chcemy pokazywać starego ducha na półce DNF!
                    var hasAnyActiveLending = g.Any(b => b.Borrows?.Any(br => br.ApplicationUserId == currentUserId &&
                                                         (br.StatusBorrow == EnumStatusBorrow.Borrowed || br.StatusBorrow == EnumStatusBorrow.Returned)) == true);

                    // 4. Jeśli nie ma żadnego aktywnego wypożyczenia ani zwrotu, bierzemy ten rekord, który ma NAJNOWSZĄ historię
                    var newestRow = g.OrderByDescending(b => b.Borrows?.Where(br => br.ApplicationUserId == currentUserId)
                                                             .Max(br => (DateTime?)br.BorrowDate) ?? DateTime.MinValue)
                                    .First();

                    // ZABEZPIECZENIE: Jeśli książka jest aktualnie wypożyczona ponownie, to stary wpis jako duch "Completed"
                    // zostaje wyczyszczony, aby nie pokazywał się na starych półkach (np. DNF).
                    if (hasAnyActiveLending && newestRow.Borrows?.Any(br => br.ApplicationUserId == currentUserId && br.StatusBorrow == EnumStatusBorrow.Completed) == true)
                    {
                        return null;
                    }

                    return newestRow;
                })
                .Where(b => b != null) // Usuwamy odrzucone stare duchy
                .ToList();
        }


        @* --- PÓŁKA: READING --- *@
        <div class="shelf-pane d-block" id="reading">
            <div class="container-books">
                @{
                    var readingBooks = uniqueUserBooks.Where(b =>
                    {
                        bool isOwner = b.ApplicationUserId == currentUserId;
                        var myBorrow = b.Borrows?.Where(br => br.ApplicationUserId == currentUserId)
                                                .OrderByDescending(br => br.BorrowDate).FirstOrDefault();

                        // 1. Właściciel: książka jest oznaczona jako Reading i nie jest aktualnie nikomu pożyczona
                        if (isOwner && b.ReadStatus == EnumReadStatus.Reading && !(b.Borrows?.Any(br => br.StatusBorrow == EnumStatusBorrow.Borrowed || br.StatusBorrow == EnumStatusBorrow.Returned) ?? false))
                            return true;

                        // 2. Wypożyczający (Aktywne wypożyczenie): Najnowsze wypożyczenie ma status Borrowed, a status czytania to Reading
                        if (!isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Borrowed && b.ReadStatus == EnumReadStatus.Reading)
                            return true;

                        // 3. Wypożyczający (Duch): Brak aktywnych wypożyczeń, stary zwrot, a końcowy status to Reading
                        if (!isOwner && myBorrow != null && (myBorrow.StatusBorrow == EnumStatusBorrow.Completed || myBorrow.StatusBorrow == EnumStatusBorrow.Returned) && myBorrow.BorrowerFinalReadStatus == EnumReadStatus.Reading)
                        {
                            // Zabezpieczenie: jeśli ta sama książka ma też jakieś inne aktywne wypożyczenie, nie pokazuj ducha
                            bool hasActive = b.Borrows?.Any(br => br.ApplicationUserId == currentUserId && br.StatusBorrow == EnumStatusBorrow.Borrowed) ?? false;
                            return !hasActive;
                        }

                        return false;
                    }).ToList();
                }

                @if (!readingBooks.Any())
                {
                    <p class="text-center py-4 no-books-msg">No books on the "Reading" shelf.</p>
                }
                else
                {
                    <div class="table-responsive shadow-sm rounded custom-table-container">
                        <table class="table table-hover align-middle mb-0 custom-library-table">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Author</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var userBook in readingBooks)
                                {
                                    bool isOwner = userBook.ApplicationUserId == currentUserId;
                                    var myBorrow = userBook.Borrows?.Where(b => b.ApplicationUserId == currentUserId).OrderByDescending(b => b.BorrowDate).FirstOrDefault();

                                    bool iAmBorrowingNow = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Borrowed;
                                    bool iReturnedThisBook = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Returned;
                                    bool iCompletedThisBook = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Completed;

                                    string rowClass = "";
                                    if (iAmBorrowingNow) rowClass = "table-success borrowed-row";
                                    else if (iReturnedThisBook || iCompletedThisBook) rowClass = "history-returned-row";

                                    <tr class="book-clickable-row book-card-item @rowClass"
                                        data-url="/UserBook/Details/@userBook.UserBookId"
                                        data-title="@userBook.Book?.Title?.ToLower()"
                                        data-author="@userBook.Book?.Author?.ToLower()">
                                        <td class="fw-bold custom-book-title-cell">
                                            @if (iAmBorrowingNow)
                                            {
                                                <i class="bi bi-box-arrow-in-down text-success me-2"></i><span class="text-success">@userBook.Book?.Title (Borrowed from Friend)</span>
                                            }
                                            else if (iReturnedThisBook || iCompletedThisBook)
                                            {
                                                <i class="bi bi-bookmark-check text-secondary me-2"></i><span>@userBook.Book?.Title (Returned to Friend)</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-book me-2"></i>
                                                @userBook.Book?.Title
                                            }
                                        </td>
                                        <td class="custom-author-text">@userBook.Book?.Author</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* --- PÓŁKA: TO READ --- *@
        <div class="shelf-pane d-none" id="toread">
            <div class="container-books">
                @{
                    var toReadBooks = uniqueUserBooks.Where(b =>
                    {
                        bool isOwner = b.ApplicationUserId == currentUserId;
                        var myBorrow = b.Borrows?.Where(br => br.ApplicationUserId == currentUserId)
                                                .OrderByDescending(br => br.BorrowDate).FirstOrDefault();

                        if (isOwner && b.ReadStatus == EnumReadStatus.ToRead && !(b.Borrows?.Any(br => br.StatusBorrow == EnumStatusBorrow.Borrowed || br.StatusBorrow == EnumStatusBorrow.Returned) ?? false))
                            return true;

                        if (!isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Borrowed && b.ReadStatus == EnumReadStatus.ToRead)
                            return true;

                        if (!isOwner && myBorrow != null && (myBorrow.StatusBorrow == EnumStatusBorrow.Completed || myBorrow.StatusBorrow == EnumStatusBorrow.Returned) && myBorrow.BorrowerFinalReadStatus == EnumReadStatus.ToRead)
                        {
                            bool hasActive = b.Borrows?.Any(br => br.ApplicationUserId == currentUserId && br.StatusBorrow == EnumStatusBorrow.Borrowed) ?? false;
                            return !hasActive;
                        }

                        return false;
                    }).ToList();
                }

                @if (!toReadBooks.Any())
                {
                    <p class="text-center py-4 no-books-msg">No books on the "To Read" shelf.</p>
                }
                else
                {
                    <div class="table-responsive shadow-sm rounded custom-table-container">
                        <table class="table table-hover align-middle mb-0 custom-library-table">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Author</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var userBook in toReadBooks)
                                {
                                    bool isOwner = userBook.ApplicationUserId == currentUserId;
                                    var myBorrow = userBook.Borrows?.Where(b => b.ApplicationUserId == currentUserId).OrderByDescending(b => b.BorrowDate).FirstOrDefault();

                                    bool iAmBorrowingNow = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Borrowed;
                                    bool iReturnedThisBook = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Returned;
                                    bool iCompletedThisBook = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Completed;

                                    string rowClass = "";
                                    if (iAmBorrowingNow) rowClass = "table-success borrowed-row";
                                    else if (iReturnedThisBook || iCompletedThisBook) rowClass = "history-returned-row";

                                    <tr class="book-clickable-row book-card-item @rowClass"
                                        data-url="/UserBook/Details/@userBook.UserBookId"
                                        data-title="@userBook.Book?.Title?.ToLower()"
                                        data-author="@userBook.Book?.Author?.ToLower()">
                                        <td class="fw-bold custom-book-title-cell">
                                            @if (iAmBorrowingNow)
                                            {
                                                <i class="bi bi-box-arrow-in-down text-success me-2"></i><span class="text-success">@userBook.Book?.Title (Borrowed from Friend)</span>
                                            }
                                            else if (iReturnedThisBook || iCompletedThisBook)
                                            {
                                                <i class="bi bi-bookmark-check text-secondary me-2"></i><span>@userBook.Book?.Title (Returned to Friend)</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-book me-2"></i>
                                                @userBook.Book?.Title
                                            }
                                        </td>
                                        <td class="custom-author-text">@userBook.Book?.Author</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* --- PÓŁKA: DNF --- *@
        <div class="shelf-pane d-none" id="dnf">
            <div class="container-books">
                @{
                    var dnfBooks = uniqueUserBooks.Where(b =>
                    {
                        bool isOwner = b.ApplicationUserId == currentUserId;
                        var myBorrow = b.Borrows?.Where(br => br.ApplicationUserId == currentUserId)
                                                .OrderByDescending(br => br.BorrowDate).FirstOrDefault();

                        if (isOwner && b.ReadStatus == EnumReadStatus.DNF && !(b.Borrows?.Any(br => br.StatusBorrow == EnumStatusBorrow.Borrowed || br.StatusBorrow == EnumStatusBorrow.Returned) ?? false))
                            return true;

                        if (!isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Borrowed && b.ReadStatus == EnumReadStatus.DNF)
                            return true;

                        if (!isOwner && myBorrow != null && (myBorrow.StatusBorrow == EnumStatusBorrow.Completed || myBorrow.StatusBorrow == EnumStatusBorrow.Returned) && myBorrow.BorrowerFinalReadStatus == EnumReadStatus.DNF)
                        {
                            bool hasActive = b.Borrows?.Any(br => br.ApplicationUserId == currentUserId && br.StatusBorrow == EnumStatusBorrow.Borrowed) ?? false;
                            return !hasActive;
                        }

                        return false;
                    }).ToList();
                }

                @if (!dnfBooks.Any())
                {
                    <p class="text-center py-4 no-books-msg">No books on the "DNF" shelf.</p>
                }
                else
                {
                    <div class="table-responsive shadow-sm rounded custom-table-container">
                        <table class="table table-hover align-middle mb-0 custom-library-table">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Author</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var userBook in dnfBooks)
                                {
                                    bool isOwner = userBook.ApplicationUserId == currentUserId;
                                    var myBorrow = userBook.Borrows?.Where(b => b.ApplicationUserId == currentUserId).OrderByDescending(b => b.BorrowDate).FirstOrDefault();

                                    bool iAmBorrowingNow = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Borrowed;
                                    bool iReturnedThisBook = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Returned;
                                    bool iCompletedThisBook = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Completed;

                                    string rowClass = "";
                                    if (iAmBorrowingNow) rowClass = "table-success borrowed-row";
                                    else if (iReturnedThisBook || iCompletedThisBook) rowClass = "history-returned-row";

                                    <tr class="book-clickable-row book-card-item @rowClass"
                                        data-url="/UserBook/Details/@userBook.UserBookId"
                                        data-title="@userBook.Book?.Title?.ToLower()"
                                        data-author="@userBook.Book?.Author?.ToLower()">
                                        <td class="fw-bold custom-book-title-cell">
                                            @if (iAmBorrowingNow)
                                            {
                                                <i class="bi bi-box-arrow-in-down text-success me-2"></i><span class="text-success">@userBook.Book?.Title (Borrowed from Friend)</span>
                                            }
                                            else if (iReturnedThisBook || iCompletedThisBook)
                                            {
                                                <i class="bi bi-bookmark-check text-secondary me-2"></i><span>@userBook.Book?.Title (Returned to Friend)</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-book me-2"></i>
                                                @userBook.Book?.Title
                                            }
                                        </td>
                                        <td class="custom-author-text">@userBook.Book?.Author</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* --- PÓŁKA: READ --- *@
        <div class="shelf-pane d-none" id="read">
            <div class="container-books">
                @{
                    var readBooks = uniqueUserBooks.Where(b =>
                    {
                        bool isOwner = b.ApplicationUserId == currentUserId;
                        var myBorrow = b.Borrows?.Where(br => br.ApplicationUserId == currentUserId)
                                                .OrderByDescending(br => br.BorrowDate).FirstOrDefault();

                        if (isOwner && b.ReadStatus == EnumReadStatus.Read && !(b.Borrows?.Any(br => br.StatusBorrow == EnumStatusBorrow.Borrowed || br.StatusBorrow == EnumStatusBorrow.Returned) ?? false))
                            return true;

                        if (!isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Borrowed && b.ReadStatus == EnumReadStatus.Read)
                            return true;

                        if (!isOwner && myBorrow != null && (myBorrow.StatusBorrow == EnumStatusBorrow.Completed || myBorrow.StatusBorrow == EnumStatusBorrow.Returned) && myBorrow.BorrowerFinalReadStatus == EnumReadStatus.Read)
                        {
                            bool hasActive = b.Borrows?.Any(br => br.ApplicationUserId == currentUserId && br.StatusBorrow == EnumStatusBorrow.Borrowed) ?? false;
                            return !hasActive;
                        }

                        return false;
                    }).ToList();
                }

                @if (!readBooks.Any())
                {
                    <p class="text-center py-4 no-books-msg">No books on the "Read" shelf.</p>
                }
                else
                {
                    <div class="table-responsive shadow-sm rounded custom-table-container">
                        <table class="table table-hover align-middle mb-0 custom-library-table">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Author</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var userBook in readBooks)
                                {
                                    bool isOwner = userBook.ApplicationUserId == currentUserId;
                                    var myBorrow = userBook.Borrows?.Where(b => b.ApplicationUserId == currentUserId).OrderByDescending(b => b.BorrowDate).FirstOrDefault();

                                    bool iAmBorrowingNow = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Borrowed;
                                    bool iReturnedThisBook = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Returned;
                                    bool iCompletedThisBook = !isOwner && myBorrow != null && myBorrow.StatusBorrow == EnumStatusBorrow.Completed;

                                    string rowClass = "";
                                    if (iAmBorrowingNow) rowClass = "table-success borrowed-row";
                                    else if (iReturnedThisBook || iCompletedThisBook) rowClass = "history-returned-row";

                                    <tr class="book-clickable-row book-card-item @rowClass"
                                        data-url="/UserBook/Details/@userBook.UserBookId"
                                        data-title="@userBook.Book?.Title?.ToLower()"
                                        data-author="@userBook.Book?.Author?.ToLower()">
                                        <td class="fw-bold custom-book-title-cell">
                                            @if (iAmBorrowingNow)
                                            {
                                                <i class="bi bi-box-arrow-in-down text-success me-2"></i><span class="text-success">@userBook.Book?.Title (Borrowed from Friend)</span>
                                            }
                                            else if (iReturnedThisBook || iCompletedThisBook)
                                            {
                                                <i class="bi bi-bookmark-check text-secondary me-2"></i><span>@userBook.Book?.Title (Returned to Friend)</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-book me-2"></i>
                                                @userBook.Book?.Title
                                            }
                                        </td>
                                        <td class="custom-author-text">@userBook.Book?.Author</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        </div>

    </div>

    <a href="/UserBook/Create" class="btn-fab shadow-lg" title="Add book to your shelf">
        <i class="bi bi-plus-lg"></i>
    </a>

</div>

@section Scripts {
    <script src="~/js/shelf.js" asp-append-version="true"></script>
}
