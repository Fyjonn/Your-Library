@model YourLibrary.Models.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<link rel="stylesheet" href="~/css/profile_style.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 pb-5 library-profile-container"
     data-stay-in-edit="@Model.StayInEditMode"
     data-has-error="@Model.HasProfileError">

    <div class="profile-header text-center mb-4">
        <h2 class="display-5 fw-bold">My Profile</h2>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-11 col-xl-10">

            <div class="profile-card p-4 text-center mb-4">

                <div id="profile-view-mode">
                    <div class="avatar-container">
                        @if (Model != null && !string.IsNullOrEmpty(Model.AvatarImagePath))
                        {
                            <img src="@Model.AvatarImagePath" class="profile-avatar-image" alt="Avatar" />
                        }
                        else
                        {
                            <span class="profile-avatar-emoji">@(Model?.Avatar ?? "🌿")</span>
                        }
                    </div>

                    <h3 class="profile-username fw-bold">@User.Identity?.Name</h3>

                    <hr class="library-divider" />

                    <button type="button" class="btn btn-library-gold w-100 py-2 fw-bold" onclick="toggleEditMode(true)">
                        <i class="bi bi-pencil-square me-2"></i>Edit Profile
                    </button>
                </div>

                <div id="profile-edit-mode" style="display: none;">
                    <h4 class="mb-4 text-start"><i class="bi bi-pencil-square me-2"></i>Edit Profile</h4>

                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="AvatarImagePath" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        <div class="mb-4 text-start">
                            <label class="form-label d-block fw-bold custom-label-muted">Choose your avatar:</label>
                            <div class="avatar-picker-grid">
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="🌿" checked><span>🌿</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="📖"><span>📖</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="🌱"><span>🌱</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="📚"><span>📚</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="🌸"><span>🌸</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="🌵"><span>🌵</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="☕"><span>☕</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="🍂"><span>🍂</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="🪴"><span>🪴</span></label>
                                <label class="avatar-option"><input asp-for="Avatar" type="radio" value="🦉"><span>🦉</span></label>
                            </div>
                        </div>

                        <div class="mb-4 text-start">
                            <label for="avatarUpload" class="form-label fw-bold custom-label-muted">Or add your own photo:</label>
                            <p>
                                <input asp-for="AvatarImage"
                                       type="file"
                                       id="avatarUpload"
                                       accept=".jpg,.jpeg,.png"
                                       style="display:none;">

                                <label for="avatarUpload" class="btn btn-outline-primary">
                                    Choose Image
                                </label>

                                <span id="selectedFileName" class="ms-2 text-muted">
                                    No file selected
                                </span>
                            </p>
                        </div>

                        <hr class="library-divider" />

                        <div class="mb-3 text-start">
                            <label class="form-label fw-bold custom-label-muted">Change Login:</label>
                            <input asp-for="DisplayName" id="loginInput" class="form-control library-input">
                            <div id="loginExistsMessage" class="text-danger small mt-1" style="display:none;">Login already taken</div>
                        </div>

                        <div class="mb-3 text-start">
                            <label class="form-label fw-bold custom-label-muted">Change Email:</label>
                            <input asp-for="Email" id="emailInput" class="form-control library-input">
                            <div id="emailExistsMessage" class="text-danger small mt-1" style="display:none;">Email already registered</div>
                        </div>

                        <div class="mb-3 text-start">
                            <label class="form-label fw-bold custom-label-muted">Change Password:</label>
                            <input asp-for="NewPassword" class="form-control library-input" id="newPassword" placeholder="Enter new password">
                        </div>

                        <div class="mb-4 text-start">
                            <label class="form-label fw-bold custom-label-muted">Confirm New Password:</label>
                            <input asp-for="ConfirmedPassword" class="form-control library-input" id="confirmPassword" placeholder="Confirm new password">
                        </div>

                        <div class="d-flex gap-3">
                            <button type="button" id="cancelEditButton" class="btn btn-library-cancel flex-grow-1" onclick="toggleEditMode(false)"> <i class="bi bi-arrow-left me-2"></i>Cancel</button>
                            <button type="submit" id="confirmProfileButton" class="btn btn-library-green flex-grow-1"><i class="bi bi-check-lg me-2"></i>Confirm</button>
                        </div>
                    </form>
                </div>

            </div>

            <div id="dashboard-widgets-row" class="row">

                <div class="col-12 col-md-6 mb-4">
                    <div class="dashboard-section-card shadow-sm h-100" data-section-url="/Shelf">
                        <div class="section-card-header">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i>Latest books u added</h5>
                        </div>
                        <div class="section-card-body mt-3">
                            <ul class="list-unstyled mb-0 dashboard-list">
                                @if (Model.LatestBooks != null && Model.LatestBooks.Any())
                                {
                                    @foreach (var book in Model.LatestBooks)
                                    {
                                        <li class="dashboard-item-row @(Model.LatestBooks.IndexOf(book) > 0 ? "mt-2" : "")">
                                            <span class="item-title fw-bold">@book.Title</span>
                                            <span class="item-sub text-muted d-block small">@book.Author</span>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="text-muted small ps-2">No books added yet.</li>
                                }
                            </ul>
                        </div>
                        <hr class="line-after" />
                        <span class="view-all-link">View All <i class="bi bi-chevron-right"></i></span>

                    </div>
                </div>

                <div class="col-12 col-md-6 mb-4">
                    <div class="dashboard-section-card shadow-sm h-100" data-section-url="/Friendship">
                        <div class="section-card-header">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>Latest friends u added</h5>
                        </div>
                        <div class="section-card-body mt-3">
                            <ul class="list-unstyled mb-0 dashboard-list">
                                @if (Model.LatestFriends != null && Model.LatestFriends.Any())
                                {
                                    @foreach (var friend in Model.LatestFriends)
                                    {
                                        <li class="dashboard-item-row">
                                            <span class="item-title fw-bold">
                                                @if (!string.IsNullOrEmpty(friend.AvatarImagePath))
                                                {
                                                    <span class="user-avatar mini-avatar me-1">
                                                        @friend.Name.Substring(0, 1).ToUpper()
                                                    </span>
                                                }
                                                else
                                                {
                                                    @friend.Avatar
                                                }
                                                @friend.Name
                                            </span>
                                            <span class="item-sub text-muted d-block small">
                                                @friend.LastActive
                                            </span>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="text-muted small ps-2">No friends added yet.</li>
                                }
                            </ul>
                        </div>
                        <hr class="line-after" />
                        <span class="view-all-link">View All <i class="bi bi-chevron-right"></i></span>

                    </div>
                </div>

                <div class="col-12 col-md-6 mb-4">
                    <div class="dashboard-section-card shadow-sm h-100" data-section-url="/Friendship">
                        <div class="section-card-header">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-box-arrow-in-right me-2"></i>Latest books u borrowed</h5>
                        </div>
                        <div class="section-card-body mt-3">
                            <ul class="list-unstyled mb-0 dashboard-list">
                                @if (Model.BorrowedBooks != null && Model.BorrowedBooks.Any())
                                {
                                    @foreach (var book in Model.BorrowedBooks)
                                    {
                                        <li class="dashboard-item-row @(Model.BorrowedBooks.IndexOf(book) > 0 ? "mt-2" : "")">
                                            <span class="item-title fw-bold">@book.Title</span>
                                            <span class="item-sub text-muted d-block small">From: @book.OwnerName</span>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="text-muted small ps-2">No borrowed books.</li>
                                }
                            </ul>

                        </div>
                        <hr class="line-after" />
                        <span class="view-all-link">View All <i class="bi bi-chevron-right"></i></span>

                    </div>
                </div>

                <div class="col-12 col-md-6 mb-4">
                    <div class="dashboard-section-card shadow-sm h-100" data-section-url="/Friendship">
                        <div class="section-card-header">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-box-arrow-up-left me-2"></i>Latest books u rented</h5>

                        </div>
                        <div class="section-card-body mt-3">
                            <ul class="list-unstyled mb-0 dashboard-list">
                                @if (Model.RentedBooks != null && Model.RentedBooks.Any())
                                {
                                    @foreach (var book in Model.RentedBooks)
                                    {
                                        <li class="dashboard-item-row @(Model.RentedBooks.IndexOf(book) > 0 ? "mt-2" : "")">
                                            <span class="item-title fw-bold">@book.Title</span>
                                            <span class="item-sub text-muted d-block small">To: @book.BorrowerName</span>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="text-muted small ps-2">No rented books.</li>
                                }
                            </ul>
                        </div>
                        <hr class="line-after" />
                        <span class="view-all-link">View All <i class="bi bi-chevron-right"></i></span>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/profile.js" asp-append-version="true"></script>
}