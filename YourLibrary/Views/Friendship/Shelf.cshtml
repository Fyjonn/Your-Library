@model YourLibrary.Models.FriendShelfViewModel
@{
    ViewData["Title"] = Model.FriendName + "'s Shelf";
    ViewData["IsFriendShelf"] = true;
    ViewData["FriendName"] = Model.FriendName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/shelf_style.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4 pb-5 position-relative library-shelf-container">

    @if (TempData["FriendSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["FriendSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["FriendError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["FriendError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="text-center mb-3">
        <h2 class="fw-bold text-secondary">
            <span id="shelf-indicator" class="text-dark">Reading</span>
        </h2>
    </div>
    <div class="text-center mb-5">
        <h1 class="page-main-title">Your Friends</h1>
    </div>

    <div class="d-flex justify-content-center mb-4">
        <div class="dropdown shadow-sm">
            <button class="btn btn-custom-dropdown btn-lg dropdown-toggle px-4" type="button" id="shelfDropdownMenu" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-filter-left me-2"></i>Select shelf
            </button>
            <ul class="dropdown-menu dropdown-menu-end text-center shadow custom-dropdown-menu" aria-labelledby="shelfDropdownMenu">
                <li><button class="dropdown-item active" type="button" data-shelf-target="#reading"><i class="bi bi-book-half me-2"></i>Reading</button></li>
                <li><button class="dropdown-item" type="button" data-shelf-target="#toread"><i class="bi bi-bookmark-plus me-2"></i>To Read</button></li>
                <li><button class="dropdown-item" type="button" data-shelf-target="#dnf"><i class="bi bi-x-circle me-2"></i>DNF</button></li>
                <li><button class="dropdown-item" type="button" data-shelf-target="#read"><i class="bi bi-check2-circle me-2"></i>Read</button></li>
            </ul>
        </div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="input-group shadow-sm mb-2 custom-search-group">
                <span class="input-group-text border-end-0 text-muted custom-search-icon">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" id="shelfSearchInput" class="form-control border-start-0 ps-1 custom-search-input" placeholder="Search books on this shelf..." />
            </div>
            <div class="d-flex justify-content-center gap-3 fs-7 custom-radio-group">
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="searchType" id="searchByTitle" value="title" checked>
                    <label class="form-check-label" for="searchByTitle">Title</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="searchType" id="searchByAuthor" value="author">
                    <label class="form-check-label" for="searchByAuthor">Author</label>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-content" id="shelfTabsContent">

@functions {
    bool IsPrintedMedia(string media)
    {
        if (string.IsNullOrEmpty(media)) return true;
        var m = media.ToLower();
        return m == "printed" || m == "paperback" || m == "hardcover" || m == "book";
    }
}

@{
    var shelves = new[] {
        new { Id = "reading", Statuses = new[] { "Reading", "Borrowed" } },
        new { Id = "toread", Statuses = new[] { "ToRead", "To Read" } },
        new { Id = "dnf", Statuses = new[] { "DNF" } },
        new { Id = "read", Statuses = new[] { "Read" } }
    };
}

@foreach (var shelf in shelves)
{
    var shelfBooks = Model.Books.Where(b => b.ReadStatus != null && shelf.Statuses.Contains(b.ReadStatus.ToString(), StringComparer.OrdinalIgnoreCase)).ToList();
    var displayClass = shelf.Id == "reading" ? "d-block" : "d-none";

    <div class="shelf-pane @displayClass" id="@shelf.Id">
        <div class="container-books">
            @if (!shelfBooks.Any())
            {
                <p class="text-center py-4 no-books-msg">No books on this shelf.</p>
            }
            else
            {
                <div class="table-responsive shadow-sm rounded custom-table-container">
                    <table class="table table-hover align-middle mb-0 custom-library-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Author</th>
                                <th class="text-end pe-4">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var userBook in shelfBooks)
                            {
                                var isPrinted = IsPrintedMedia(userBook.Media.ToString());
                                var isReturned = userBook.ReadStatus.ToString().Equals("Returned", StringComparison.OrdinalIgnoreCase);

                                <tr class="book-card-item @(userBook.IsBorrowed ? "table-success" : "")" style="@(userBook.IsBorrowed ? "background-color: rgba(46, 204, 113, 0.08);" : "")">

                                    <td class="fw-bold custom-book-title-cell text-dark"
                                        data-title="@userBook.Book?.Title?.ToLower()"
                                        data-author="@userBook.Book?.Author?.ToLower()">
                                        <i class="bi bi-book me-2 text-secondary"></i>@userBook.Book?.Title
                                    </td>

                                    <td class="custom-author-text text-secondary">
                                        @userBook.Book?.Author
                                    </td>

                                    <td class="text-end pe-4">
                                        @if (userBook.IsBorrowed || userBook.ReadStatus.ToString() == "Borrowed")
                                        {
                                            <span class="badge bg-success rounded-pill px-3 py-2">
                                                <i class="bi bi-journal-arrow-down me-1"></i>Borrowed
                                            </span>
                                        }
                                        else if (isReturned)
                                        {
                                            <span class="badge bg-secondary rounded-pill px-3 py-2" title="This book was returned to the owner">
                                                <i class="bi bi-arrow-left-right me-1"></i>Returned to Owner
                                            </span>
                                        }
                                        else if (!isPrinted)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled title="Digital formats cannot be borrowed">
                                                <i class="bi bi-phone-mute me-1"></i> Digital
                                            </button>
                                        }
                                        else
                                        {
                                            <form asp-action="RequestBorrow" method="post" class="d-inline">
                                                <input type="hidden" name="userBookId" value="@userBook.UserBookId" />
                                                <input type="hidden" name="friendName" value="@Model.FriendName" />
                                                <button type="submit" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm fw-bold">
                                                    <i class="bi bi-box-arrow-in-right me-1"></i> Ask to Borrow
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

</div>

@section Scripts {
    <script src="~/js/friendship_shelf.js" asp-append-version="true"></script>
}