@model YourLibrary.Models.FriendshipPageViewModel

@{
    ViewData["Title"] = "Friends";
}

@section Styles {
    <link rel="stylesheet" href="~/css/friendship_style.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container friendship-page-container mt-5 pb-5">

    <div class="text-center mb-5">
        <h1 class="page-main-title">Your Friends</h1>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="friend-search-card p-4 shadow h-100 d-flex flex-column justify-content-center">
                <h6 class="fw-bold search-headline mb-3">Add new friend</h6>

                @if (TempData["FriendError"] != null)
                {
                    <div id="friendErrorAlert" class="alert alert-danger alert-dismissible fade show">@TempData["FriendError"]</div>
                }

                <form asp-action="SendInvitation" method="post" class="w-100">
                    <div class="input-group">
                        <span class="input-group-text search-icon-box"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchUsername" class="form-control search-input" placeholder="Enter username..." required />
                        <button type="submit" class="btn btn-library-submit px-4">
                            Send invitation
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="invitations-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3">Waiting Invitations</h6>

                <div class="scroll-content-small">

                    @foreach (var item in Model.SentInvitations)
                    {
                        <div class="card invitation-card">
                            <div class="card-body">
                                <div class="invitation-card-content">
                                    <div class="user-avatar">
                                        @if (!string.IsNullOrEmpty(item.Receiver.AvatarImagePath))
                                        {
                                            <img src="@item.Receiver.AvatarImagePath" alt="Avatar" class="avatar-circle-img" />
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(item.Receiver.Avatar) ? item.Receiver.UserName.Substring(0, 1).ToUpper() : item.Receiver.Avatar)
                                        }
                                    </div>

                                    <div class="invitation-info">
                                        <span class="username">@item.Receiver.UserName</span>
                                        <span class="text-muted">Invitation sent</span>
                                    </div>
                                </div>

                                <a asp-action="CancelInvitation" asp-route-friendshipId="@item.FriendshipId" class="btn btn-outline-danger">Cancel</a>
                            </div>
                        </div>
                    }

                    @foreach (var item in Model.ReceivedInvitations)
                    {
                        <div class="card invitation-card">
                            <div class="card-body">
                                <div class="invitation-card-content">
                                    <div class="user-avatar">
                                        @if (!string.IsNullOrEmpty(item.Requester.AvatarImagePath))
                                        {
                                            <img src="@item.Requester.AvatarImagePath" alt="Avatar" class="avatar-circle-img" />
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(item.Requester.Avatar) ? item.Requester.UserName.Substring(0, 1).ToUpper() : item.Requester.Avatar)
                                        }
                                    </div>

                                    <div class="invitation-info">
                                        <span class="username">@item.Requester.UserName</span>
                                        <span class="text-muted">Received request</span>
                                    </div>
                                </div>

                                <div class="d-flex gap-2">
                                    <form asp-action="AcceptInvitation" method="post" class="d-inline">
                                        <input type="hidden" name="friendshipId" value="@item.FriendshipId" />
                                        <button type="submit" class="btn btn-sm btn-success px-3">Accept</button>
                                    </form>
                                    <form asp-action="RejectInvitation" method="post" class="d-inline">
                                        <input type="hidden" name="friendshipId" value="@item.FriendshipId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3">Reject</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>

    <div class="friends-list-section p-4 mb-4 shadow">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-3 gap-2">
            <h5 class="fw-bold list-headline mb-0">List of friends (@Model.Friends.Count)</h5>
            <div class="input-group list-search-box">
                <span class="input-group-text search-icon-box"><i class="bi bi-filter"></i></span>
                <input type="text" id="inlineFriendSearch" class="form-control search-input" placeholder="Search friend from list..." onkeyup="filterFriendsList()" />
            </div>
        </div>

        <div class="friends-scroll-viewport">
            <div class="row row-cols-1 g-2" id="friendsContainer">

                @foreach (var item in Model.Friends)
                {
                    var friend = item.Requester.UserName == User.Identity.Name ? item.Receiver : item.Requester;

                    <div class="card friend-card friend-list-item-row" data-username="@friend.UserName.ToLower()">
                        <div class="card-body">
                            <div class="friend-card-content">
                                <div class="user-avatar">
                                    @if (!string.IsNullOrEmpty(friend.AvatarImagePath))
                                    {
                                        <img src="@friend.AvatarImagePath" alt="Avatar" class="avatar-circle-img" />
                                    }
                                    else
                                    {
                                        @(string.IsNullOrEmpty(friend.Avatar) ? friend.UserName.Substring(0, 1).ToUpper() : friend.Avatar)
                                    }
                                </div>

                                <div class="friend-info">
                                    <span class="username">@friend.UserName</span>
                                    <span class="badge-friend">Friend</span>
                                </div>
                            </div>

                            <button type="button" class="btn-delete-friend" data-bs-toggle="modal" data-bs-target="#deleteFriendModal" data-friend-name="@friend.UserName" data-friend-id="@item.FriendshipId">
                                Cancel friend
                            </button>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="borrow-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3"><i class="bi bi-box-arrow-in-right me-2"></i>Books u Borrowed</h6>
                <div class="borrow-list-container">
                    <div class="p-3 mb-2 rounded border custom-item-row d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-bold d-block text-dark">Władca Pierścieni</span>
                            <small class="text-muted">From: BookWorm99</small>
                        </div>
                        <span class="badge bg-secondary rounded-pill px-3">Borrowed</span>
                    </div>
                    <div class="p-3 mb-2 rounded border custom-item-row d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-bold d-block text-dark">Duma i Uprzedzenie</span>
                            <small class="text-muted">From: eliza_reads</small>
                        </div>
                        <span class="badge bg-secondary rounded-pill px-3">Borrowed</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="rent-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3"><i class="bi bi-box-arrow-up-left me-2"></i>Books You Rented</h6>
                <div class="borrow-list-container">
                    <div class="p-3 mb-2 rounded border custom-item-row d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-bold d-block text-dark">Wiedźmin: Ostatnie Życzenie</span>
                            <small class="text-muted">To: czytelnik_marian</small>
                        </div>
                        <span class="badge bg-success text-white rounded-pill px-3">Rented</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteFriendModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="DeleteFriend" method="post">
                <input type="hidden" id="friendshipIdInput" name="friendshipId" />

                <div class="modal-header bg-danger text-white py-2">
                    <h6 class="modal-title fw-bold">Confirmation</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <p class="mb-1 text-dark">Are you sure you want to end this friendship with</p>
                    <h5 class="fw-bold text-danger" id="modal-friend-name">Użytkownik</h5>
                </div>
                <div class="modal-footer justify-content-center border-0 pt-0 pb-3">
                    <button type="submit" class="btn btn-danger btn-sm px-4 me-2">Yes</button>
                    <button type="button" class="btn btn-light btn-sm px-4 border" data-bs-dismiss="modal">No</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterFriendsList() {
            let input = document.getElementById('inlineFriendSearch').value.toLowerCase();
            let items = document.querySelectorAll('.friend-list-item-row');
            items.forEach(function(item) {
                let username = item.getAttribute('data-username');
                if (username.includes(input)) {
                    item.style.setProperty('display', 'block', 'important');
                } else {
                    item.style.setProperty('display', 'none', 'important');
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            const modal = document.getElementById('deleteFriendModal');
            if (modal) {
                modal.addEventListener('show.bs.modal', function(event) {
                    const button = event.relatedTarget;
                    const friendName = button.getAttribute('data-friend-name');
                    const friendshipId = button.getAttribute('data-friend-id');

                    document.getElementById('modal-friend-name').textContent = friendName;
                    document.getElementById('friendshipIdInput').value = friendshipId;
                });
            }

            const alert = document.getElementById("friendErrorAlert");
            if (alert) {
                setTimeout(function() {
                    alert.classList.remove("show");
                    setTimeout(function() {
                        alert.remove();
                    }, 300)
                }, 3000)
            }
        });
    </script>
}