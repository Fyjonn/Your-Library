@model YourLibrary.Models.FriendshipPageViewModel

@{
    ViewData["Title"] = "Friends";
}

@section Styles {
    <link rel="stylesheet" href="~/css/friendship_style.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container friendship-page-container mt-5 pb-5">

    <div class="text-center mb-5">
        <h1 class="page-main-title">Your Friends</h1>
    </div>

    <!--
    <p>Received: @Model.ReceivedInvitations.Count</p>
    <p>Sent: @Model.SentInvitations.Count</p>
    <p>Friends: @Model.Friends.Count</p>
    -->

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="friend-search-card p-4 shadow h-100 d-flex flex-column justify-content-center">
                <h6 class="fw-bold search-headline mb-3">Add new friend</h6>

                @if(TempData["FriendError"] != null)
                {
                    <div id="friendErrorAlert" class="alert alert-danger alert-dismissible fade show">@TempData["FriendError"]</div>
                }

                <form asp-action="SendInvitation" method="post" class="w-100">
                    <div class="input-group">
                        <span class="input-group-text search-icon-box"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchUsername" class="form-control search-input" placeholder="Enter username..." required />
                        <button type="submit" class="btn btn-library-submit px-4">
                            Send invitation
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="invitations-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3">Waiting Invitations</h6>

                <div class="scroll-content-small">
                    <!--tu mozesz to nizej zedytowac stylistycznie Emilia-->
                    @foreach (var invitation in Model.SentInvitations)
                    {
                        <div class="card invitation-card mb-2 border-0 shadow-sm">
                            <div class="card-body d-flex align-items-center justify-content-between p-2">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar mini-avatar me-2">
                                        @invitation.Receiver.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                </div>

                                <div>
                                    <h6 class="fw-bold mb-0 text-dark small">
                                        @invitation.Receiver.UserName
                                    </h6>

                                    <small class="text-muted" style="font-size: 0.75rem;">Invitation sent</small>

                                </div>
                            </div>

                            <div class="d-flex gap-1">
                                <span class="badge bg-secondary rounded-pill">Pending</span>

                                <form asp-action="CancelInvitation" method="post" class="d-inline">

                                    <input type="hidden" name="friendshipId" value="@invitation.FriendshipId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill">Cancel</button>

                                </form>
                            </div>
                        </div>
                    }

                    @foreach (var invitation in Model.ReceivedInvitations)
                    {
                        <div class="card invitation-card mb-2 border-0 shadow-sm">
                            <div class="card-body d-flex align-items-center justify-content-between p-2">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar mini-avatar me-2">
                                        @invitation.Receiver.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0 text-dark small">@invitation.Requester.UserName</h6>
                                        <small class="text-muted" style="font-size: 0.75rem;">Wants to be your friend</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-1">
                                    <form asp-action="AcceptInvitation" method="post">
                                        <input type="hidden" name="friendshipId" value="@invitation.FriendshipId" />
                                        <button type="submit" class="btn btn-success btn-sm py-0 px-2 rounded-pill" style="font-size: 0.8rem;">Yes</button>
                                    </form>

                                    <form asp-action="RejectInvitation" method="post">
                                        <input type="hidden" name="friendshipId" value="@invitation.FriendshipId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-2 rounded-pill" style="font-size: 0.8rem;">No</button>
                                    </form>

                                </div>
                            </div>
                        </div>
                    }

                    
                    @* <div class="card invitation-card mb-2 border-0 shadow-sm"> *@
                    @*     <div class="card-body d-flex align-items-center justify-content-between p-2"> *@
                    @*         <div class="d-flex align-items-center"> *@
                    @*             <div class="user-avatar mini-avatar me-2">T</div> *@
                    @*             <div> *@
                    @*                 <h6 class="fw-bold mb-0 text-dark small">Tomasz90</h6> *@
                    @*                 <small class="text-muted" style="font-size: 0.75rem;">Chce dołączyć do znajomych</small> *@
