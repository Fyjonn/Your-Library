                        <div class="card friend-card border-0 shadow-sm">
                            <div class="card-body d-flex align-items-center justify-content-between p-3">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar friend-avatar text-white me-3">@friend.UserName.Substring(0,1).ToUpper()</div>
                                    <div>
                                        <h6 class="fw-bold mb-0 text-dark">@friend.UserName</h6>
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill" style="font-size: 0.7rem;">Friend</span>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-outline-danger btn-sm rounded-circle p-2" data-bs-toggle="modal" data-bs-target="#deleteFriendModal" data-friend-name="@friend.UserName" data-friend-id="@friendship.FriendshipId">
                                    <i class="bi bi-person-x-fill px-1"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                }

