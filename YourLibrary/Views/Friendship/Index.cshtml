@model YourLibrary.Models.FriendshipPageViewModel

@{
    ViewData["Title"] = "Friends";
}

@section Styles {
    <link rel="stylesheet" href="~/css/friendship_style.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container friendship-page-container mt-5 pb-5">

    <div class="text-center mb-5">
        <h1 class="page-main-title">Your Friends</h1>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            @if (TempData["FriendSuccess"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-check-circle-fill fs-5"></i>
                    <div>@TempData["FriendSuccess"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["FriendError"] != null && !ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3 d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <div>@TempData["FriendError"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>

    @if (Model.IncomingBorrowRequests != null && Model.IncomingBorrowRequests.Any())
    {
        <div class="mb-4">
            @foreach (var request in Model.IncomingBorrowRequests)
            {
                <div class="alert alert-warning border border-warning shadow-sm d-flex justify-content-between align-items-center py-3 px-4 rounded-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-circle-fill text-warning fs-5"></i>
                        <span class="text-dark">
                            <strong>@request.ApplicationUser.UserName</strong> wants to borrow <strong>@request.UserBook.Book?.Title</strong> from you.
                        </span>
                    </div>
                    <div class="d-flex gap-2">
                        <form asp-action="AcceptBorrow" method="post" class="m-0">
                            <input type="hidden" name="borrowId" value="@request.BorrowId" />
                            <button type="submit" class="btn btn-sm btn-success px-3 rounded-pill fw-bold">Lend</button>
                        </form>
                        <form asp-action="RejectBorrow" method="post" class="m-0">
                            <input type="hidden" name="borrowId" value="@request.BorrowId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger px-3 rounded-pill">Reject</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }

    @if (ViewBag.ReturnsToConfirm != null && ((List<YourLibrary.Models.Borrow>)ViewBag.ReturnsToConfirm).Any())
    {
        <div class="mb-4">
            @foreach (var item in (List<YourLibrary.Models.Borrow>)ViewBag.ReturnsToConfirm)
            {
                <div class="alert alert-info border border-info shadow-sm d-flex justify-content-between align-items-center py-3 px-4 rounded-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-arrow-counterclockwise text-info fs-5"></i>
                        <span class="text-dark">
                            <strong>@item.ApplicationUser?.UserName</strong> returned your book: <strong>@item.UserBook.Book?.Title</strong>. Please confirm receipt.
                        </span>
                    </div>
                    <div>
                        <form asp-action="ConfirmReturn" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="borrowId" value="@item.BorrowId" />
                            <button type="submit" class="btn btn-sm btn-info text-white px-3 rounded-pill fw-bold">
                                <i class="bi bi-check2-all me-1"></i>Confirm Return
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="friend-search-card p-4 shadow h-100 d-flex flex-column justify-content-center">
                <h6 class="fw-bold search-headline mb-3">Add new friend</h6>

                @if (TempData["FriendError"] != null)
                {
                    <div id="friendErrorAlert" class="alert alert-danger alert-dismissible fade show">@TempData["FriendError"]</div>
                }

                <form asp-action="SendInvitation" method="post" class="w-100">
                    <div class="input-group">
                        <span class="input-group-text search-icon-box"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchUsername" class="form-control search-input" placeholder="Enter username..." required />
                        <button type="submit" class="btn btn-library-submit px-4">
                            Send invitation
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="invitations-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3">Waiting Invitations</h6>
                <div class="scroll-content-small">
                    @foreach (var item in Model.SentInvitations)
                    {
                        <div class="card invitation-card">
                            <div class="card-body">
                                <div class="invitation-card-content">
                                    <div class="user-avatar">
                                        @if (!string.IsNullOrEmpty(item.Receiver.AvatarImagePath))
                                        {
                                            <img src="@item.Receiver.AvatarImagePath" alt="Avatar" class="avatar-circle-img" />
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(item.Receiver.Avatar) ? item.Receiver.UserName.Substring(0, 1).ToUpper() : item.Receiver.Avatar)
                                        }
                                    </div>
                                    <div class="invitation-info">
                                        <span class="username">@item.Receiver.UserName</span>
                                        <span class="text-muted">Invitation sent</span>
                                    </div>
                                </div>
                                <a asp-action="CancelInvitation" asp-route-friendshipId="@item.FriendshipId" class="btn btn-outline-danger">Cancel</a>
                            </div>
                        </div>
                    }

                    @foreach (var item in Model.ReceivedInvitations)
                    {
                        <div class="card invitation-card">
                            <div class="card-body">
                                <div class="invitation-card-content">
                                    <div class="user-avatar">
                                        @if (!string.IsNullOrEmpty(item.Requester.AvatarImagePath))
                                        {
                                            <img src="@item.Requester.AvatarImagePath" alt="Avatar" class="avatar-circle-img" />
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(item.Requester.Avatar) ? item.Requester.UserName.Substring(0, 1).ToUpper() : item.Requester.Avatar)
                                        }
                                    </div>
                                    <div class="invitation-info">
                                        <span class="username">@item.Requester.UserName</span>
                                        <span class="text-muted">Received request</span>
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <form asp-action="AcceptInvitation" method="post" class="d-inline">
                                        <input type="hidden" name="friendshipId" value="@item.FriendshipId" />
                                        <button type="submit" class="btn btn-sm btn-success px-3">Accept</button>
                                    </form>
                                    <form asp-action="RejectInvitation" method="post" class="d-inline">
                                        <input type="hidden" name="friendshipId" value="@item.FriendshipId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3">Reject</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="friends-list-section p-4 mb-4 shadow">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-3 gap-2">
            <h5 class="fw-bold list-headline mb-0">List of friends (@Model.Friends.Count)</h5>
            <div class="input-group list-search-box">
                <span class="input-group-text search-icon-box"><i class="bi bi-filter"></i></span>
                <input type="text" id="inlineFriendSearch" class="form-control search-input" placeholder="Search friend from list..." onkeyup="filterFriendsList()" />
            </div>
        </div>

        <div class="friends-scroll-viewport">
            <div class="row row-cols-1 g-2" id="friendsContainer" style="margin: 0;">
                @foreach (var item in Model.Friends)
                {
                    var friend = item.Requester.UserName == User.Identity.Name ? item.Receiver : item.Requester;

                    <div class="card friend-card friend-list-item-row" data-username="@friend.UserName.ToLower()">
                        <div class="card-body">
                            <a asp-action="Shelf" asp-route-friendName="@friend.UserName" class="text-decoration-none d-flex align-items-center justify-content-between w-100 me-3">
                                <div class="friend-card-content">
                                    <div class="user-avatar">
                                        @if (!string.IsNullOrEmpty(friend.AvatarImagePath))
                                        {
                                            <img src="@friend.AvatarImagePath" alt="Avatar" class="avatar-circle-img" />
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(friend.Avatar) ? friend.UserName.Substring(0, 1).ToUpper() : friend.Avatar)
                                        }
                                    </div>
                                    <div class="friend-info">
                                        <span class="username">@friend.UserName</span>
                                        <span class="badge-friend"><i class="bi bi-folder2-open me-1"></i>View Shelf</span>
                                    </div>
                                </div>
                            </a>

                            <button type="button" class="btn-delete-friend" data-bs-toggle="modal" data-bs-target="#deleteFriendModal" data-friend-name="@friend.UserName" data-friend-id="@item.FriendshipId">
                                Cancel friend
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="borrow-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3"><i class="bi bi-box-arrow-in-right me-2"></i>Books u Borrowed</h6>
                <div class="borrow-list-container">
                    @if (Model.MyBorrowedBooks == null || !Model.MyBorrowedBooks.Any())
                    {
                        <p class="text-muted fs-7 italic text-center py-3">No borrowed books.</p>
                    }
                    else
                    {
                        @foreach (var b in Model.MyBorrowedBooks)
                        {
                            <div class="p-3 mb-2 rounded border border-success custom-item-row d-flex justify-content-between align-items-center" style="background-color: rgba(46, 204, 113, 0.05);">
                                <div>
                                    <span class="fw-bold d-block text-dark">@b.UserBook.Book?.Title</span>
                                    <small class="text-muted"><i class="bi bi-person-arrow-left me-1"></i>From: @b.UserBook.ApplicationUser?.UserName</small>
                                </div>
                                <span class="badge custom-badge-borrowed rounded-pill px-3"><i class="bi bi-journal-arrow-down me-1"></i>Borrowed</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="rent-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3"><i class="bi bi-box-arrow-up-left me-2"></i>Books You Rented</h6>
                <div class="borrow-list-container">
                    @if (Model.MyRentedBooks == null || !Model.MyRentedBooks.Any())
                    {
                        <p class="text-muted fs-7 italic text-center py-3">No rented books.</p>
                    }
                    else
                    {
                        @foreach (var r in Model.MyRentedBooks)
                        {
                            <div class="p-3 mb-2 rounded border border-primary custom-item-row d-flex justify-content-between align-items-center" style="background-color: rgba(0, 123, 255, 0.05);">
                                <div>
                                    <span class="fw-bold d-block text-dark">@r.UserBook.Book?.Title</span>
                                    <small class="text-muted"><i class="bi bi-person-arrow-right me-1"></i>To: @r.ApplicationUser?.UserName</small>
                                </div>
                                <span class="badge custom-badge-rented rounded-pill px-3"><i class="bi bi-journal-arrow-up me-1"></i>Rented</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-lg-6">
            <div class="history-borrow-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3"><i class="bi bi-clock-history me-2"></i>Borrowed History</h6>
                <div class="borrow-list-container">
                    @if (Model.MyBorrowedHistory == null || !Model.MyBorrowedHistory.Any())
                    {
                        <p class="text-muted fs-7 italic text-center py-3">No borrow history.</p>
                    }
                    else
                    {
                        @foreach (var b in Model.MyBorrowedHistory)
                        {
                            <div class="p-3 mb-2 rounded border border-secondary custom-item-row d-flex justify-content-between align-items-center" style="background-color: rgba(108, 117, 125, 0.05);">
                                <div>
                                    <span class="fw-bold d-block text-dark">@b.UserBook.Book?.Title</span>
                                    <small class="text-muted"><i class="bi bi-person-check me-1"></i>Borrowed from: @b.UserBook.ApplicationUser?.UserName</small>
                                </div>
                                <span class="badge custom-badge-returned rounded-pill px-3"><i class="bi bi-arrow-counterclockwise me-1"></i>Returned</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="history-rent-section p-4 shadow h-100">
                <h6 class="fw-bold section-headline mb-3"><i class="bi bi-clock-history me-2"></i>Rented History</h6>
                <div class="borrow-list-container">
                    @if (Model.MyRentedHistory == null || !Model.MyRentedHistory.Any())
                    {
                        <p class="text-muted fs-7 italic text-center py-3">No rent history.</p>
                    }
                    else
                    {
                        @foreach (var r in Model.MyRentedHistory)
                        {
                            <div class="p-3 mb-2 rounded border border-secondary custom-item-row d-flex justify-content-between align-items-center" style="background-color: rgba(108, 117, 125, 0.05);">
                                <div>
                                    <span class="fw-bold d-block text-dark">@r.UserBook.Book?.Title</span>
                                    <small class="text-muted"><i class="bi bi-person-check me-1"></i>Returned by: @r.ApplicationUser?.UserName</small>
                                </div>
                                <span class="badge custom-badge-returned rounded-pill px-3"><i class="bi bi-check-lg me-1"></i>Got Back</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteFriendModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="DeleteFriend" method="post">
                <input type="hidden" id="friendshipIdInput" name="friendshipId" />
                <div class="modal-header bg-danger text-white py-2">
                    <h6 class="modal-title fw-bold">Confirmation</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <p class="mb-1 text-dark">Are you sure you want to end this friendship with</p>
                    <h5 class="fw-bold text-danger" id="modal-friend-name">Użytkownik</h5>
                </div>
                <div class="modal-footer justify-content-center border-0 pt-0 pb-3">
                    <button type="submit" class="btn btn-danger btn-sm px-4 me-2">Yes</button>
                    <button type="button" class="btn btn-light btn-sm px-4 border" data-bs-dismiss="modal">No</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/friendship.js" asp-append-version="true"></script>
}