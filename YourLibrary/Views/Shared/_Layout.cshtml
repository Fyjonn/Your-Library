@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YourLibrary</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/YourLibrary.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="site-wrapper">
    <div class="page-container">

        @if (ViewData["HideNavbar"] == null)
        {
            <header>
                <nav class="navbar navbar-expand-md navbar-dark box-shadow">
                    <div class="container-fluid">

                        @if (ViewData["IsFriendShelf"] != null)
                        {
                            <div class="d-flex align-items-center justify-content-between w-100 py-1">
                                <a asp-controller="Friendship" asp-action="Index" class="btn btn-outline-light d-flex align-items-center gap-2 px-3 py-1.5 rounded-pill text-white backend-back-btn">
                                    <i class="bi bi-arrow-left"></i> <span>Back</span>
                                </a>

                                <span class="navbar-brand m-0 h4 fw-bold text-white ms-auto font-serif tracking-wide friend-shelf-title">
                                    @ViewData["FriendName"]'s Shelf 
                                </span>
                            </div>
                        }
                        else
                        {
                            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MYLIBRARY</a>

                            @if (SignInManager.IsSignedIn(User))
                            {
                                var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

                                if (currentController == "Home")
                                {
                                    <div class="d-flex align-items-center ms-auto">
                                        <ul class="navbar-nav flex-row">
                                            <li class="nav-item">
                                                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                                    <button type="submit" class="nav-link logout-btn-link px-2">
                                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#libraryNavbar" aria-controls="libraryNavbar"
                                            aria-expanded="false" aria-label="Toggle navigation">
                                        <span class="navbar-toggler-icon"></span>
                                    </button>

                                    <div class="collapse navbar-collapse" id="libraryNavbar">
                                        <ul class="navbar-nav ms-auto mt-2 mt-md-0">
                                            <li class="nav-item">
                                                <a class="nav-link @(currentController == "Profile" ? "active" : "")" asp-area="" asp-controller="Profile" asp-action="Index">
                                                    <i class="bi bi-person me-2"></i>My Profile
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link @(currentController == "Shelf" ? "active" : "")" asp-area="" asp-controller="Shelf" asp-action="Index">
                                                    <i class="bi bi-bookshelf me-2"></i>My Shelf
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link @(currentController == "Friendship" ? "active" : "")" asp-area="" asp-controller="Friendship" asp-action="Index">
                                                    <i class="bi bi-people me-2"></i>Friendship
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                                    <button type="submit" class="nav-link logout-btn-link">
                                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                }
                            }
                        }
                    </div>
                </nav>
            </header>
        }

        <div class="container main-content mt-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
   
</body>
</html>